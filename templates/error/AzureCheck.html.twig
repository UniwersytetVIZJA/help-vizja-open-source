{% extends 'student/_layouts/before-login.html.twig' %}
{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}

{% block title %}{% trans %}Błąd strony{% endtrans %} | Help VIZJA{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}

{% block body %}
    <section class="min-h-screen px-4 py-8 sm:py-10">
        <div class="mx-auto flex w-full max-w-5xl flex-col items-center gap-10">

            <div class="flex w-full max-w-3xl items-center justify-center gap-5 sm:gap-8">
                <figure class="flex flex-1 justify-end">
                    <img
                        alt="{% trans %}Uniwersytet Vizja{% endtrans %}"
                        class="block h-auto w-full max-w-[150px] sm:max-w-[230px] md:max-w-[300px] dark:hidden"
                        src="{{ asset('images/logo/header/' ~ app.request.locale ~ '.png') }}"
                    >

                    <img
                        alt="{% trans %}Uniwersytet Vizja{% endtrans %}"
                        class="hidden h-auto w-full max-w-[150px] sm:max-w-[230px] md:max-w-[300px] dark:block"
                        src="{{ asset('images/logo/header/' ~ app.request.locale ~ '-transparent.png') }}"
                    >
                </figure>

                <figure class="flex flex-1 justify-start">
                    <img
                        alt="{% trans %}Logo Biura do spraw osób z niepełnosprawnościami{% endtrans %}"
                        class="block h-auto w-full max-w-[150px] sm:max-w-[230px] md:max-w-[300px]"
                        src="{{ asset('images/logo/bon/' ~ app.request.locale ~ '.jpg') }}"
                    >
                </figure>
            </div>

            <div class="flex w-full flex-1 items-start justify-center pt-4 sm:pt-8">
                <div class="w-full max-w-xl rounded-2xl bg-white px-6 py-8 text-center shadow-xl dark:bg-zinc-900 sm:px-8">
                    <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full border-2 border-rose-400 bg-rose-50 text-rose-700 dark:bg-zinc-800 dark:text-rose-300">
                        <svg class="h-7 w-7" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                            <path fill-rule="evenodd"
                                  d="M8 10V7a4 4 0 1 1 8 0v3h1a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h1Zm2-3a2 2 0 1 1 4 0v3h-4V7Zm2 6a1 1 0 0 1 1 1v3a1 1 0 1 1-2 0v-3a1 1 0 0 1 1-1Z"
                                  clip-rule="evenodd" />
                        </svg>
                    </div>

                    <h1 class="mb-3 text-2xl font-bold text-zinc-900 dark:text-white">
                        {% trans %}Brak dostępu{% endtrans %}
                    </h1>

                    <p class="mx-auto mb-5 max-w-md text-base text-zinc-700 dark:text-zinc-200">
                        {% trans %}Nie posiadasz uprawnień do wyświetlania lub edytowania tej strony.{% endtrans %}
                    </p>

                    {% if message is defined and message %}
                        <div class="mx-auto mb-8 max-w-md rounded-xl border border-zinc-200 bg-zinc-50 p-4 text-left text-sm text-zinc-700 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-200">
                            <p class="mb-1 font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Komunikat lub kod błędu{% endtrans %}
                            </p>

                            <p class="break-words">
                                {{ message }}
                            </p>
                        </div>
                    {% endif %}

                    <a
                        href="{{ path('logout_full') }}"
                        class="cursor-pointer {{ buttonPrimary() }}"
                    >
                        {% trans %}Zaloguj się na inne konto{% endtrans %}
                    </a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
