{% if pageCount > 1 %}
    <ul class="inline-flex items-stretch">
        {% if previous is defined %}
            <li>
                <a href="{{ path(route, knp_pagination_query(query, previous, options)) }}"
                    class="bg-white border-zinc-300 flex h-full items-center justify-center ml-0 px-3 py-1.5 rounded-l-lg text-gray-500 dark:bg-zinc-800 dark:border-zinc-700 dark:hover:bg-zinc-700 dark:hover:text-white dark:text-gray-400 hover:bg-zinc-100 hover:text-gray-700 {{ focusPrimary() }}"
                >
                    <span class="sr-only">{% trans %}Poprzednia strona{% endtrans %}</span>
                    <svg class="h-5 w-5" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                </a>
            </li>
        {% else %}
            <li>
                <a href="#"
                    class="bg-white border-zinc-300 flex h-full items-center justify-center ml-0 px-3 py-1.5 rounded-l-lg text-gray-500 dark:bg-zinc-800 dark:border-zinc-700 dark:hover:bg-zinc-700 dark:hover:text-white dark:text-gray-400 hover:bg-zinc-100 hover:text-gray-700 {{ focusPrimary() }}"
                >
                    <span class="sr-only">{% trans %}Poprzednia strona{% endtrans %}</span>
                    <svg class="h-5 w-5" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                </a>
            </li>
        {% endif %}

        {% for page in pagesInRange %}
            {% if page != current %}
                <li>
                    <a href="{{ path(route, knp_pagination_query(query, page, options)) }}"
                        class="bg-white border-zinc-300 flex h-full items-center justify-center ml-0 px-3 py-1.5 text-gray-500 dark:bg-zinc-800 dark:border-zinc-700 dark:hover:bg-zinc-700 dark:hover:text-white dark:text-gray-400 hover:bg-zinc-100 hover:text-gray-700 {{ focusPrimary() }}"
                    >
                        {{ page }}
                    </a>
                </li>
            {% else %}
                <li>
                    <span
                        aria-current="page"
                        class="
                        bg-blue-600 border-zinc-300 flex h-full items-center justify-center ml-0 px-3 py-1.5 text-white dark:bg-yellow-400 dark:border-zinc-700 dark:text-zinc-950 {{ focusPrimary() }}"
                    >
                        {{ page }}
                    </span>
                </li>
            {% endif %}
        {% endfor %}

        {% if next is defined %}
            <li>
                <a href="{{ path(route, knp_pagination_query(query, next, options)) }}"
                    class="bg-white border-zinc-300 flex h-full items-center justify-center leading-tight px-3 py-1.5 rounded-r-lg text-gray-500 dark:bg-zinc-800 dark:border-zinc-700 dark:hover:bg-zinc-700 dark:hover:text-white dark:text-gray-400 hover:bg-zinc-100 hover:text-gray-700 {{ focusPrimary() }}"
                >
                    <span class="sr-only">{% trans %}Następna strona{% endtrans %}</span>
                    <svg class="h-5 w-5" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                    </svg>
                </a>
            </li>
        {% else %}
            <li>
                <a href="#"
                    class="bg-white border-zinc-300 flex h-full items-center justify-center leading-tight px-3 py-1.5 rounded-r-lg text-gray-500 dark:bg-zinc-800 dark:border-zinc-700 dark:hover:bg-zinc-700 dark:hover:text-white dark:text-gray-400 hover:bg-zinc-100 hover:text-gray-700 {{ focusPrimary() }}"
                >
                    <span class="sr-only">{% trans %}Następna strona{% endtrans %}</span>
                    <svg class="h-5 w-5" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                    </svg>
                </a>
            </li>
        {% endif %}
    </ul>
{% endif %}
