        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const cookieModal = document.getElementById('cookie-consent');
                const cookieAcceptButton = document.getElementById('cookie-consent-accept');

                const browserModalElement = document.getElementById('browser-info-modal');
                const browserAcceptButton = document.getElementById('browser-info-accept');

                const STORAGE_KEY = 'help_vizja_browser_info_last_seen';
                const ONE_HOUR = 60 * 60 * 1000;

                let activeTrapContainer = null;
                let previouslyFocusedElement = null;
                let browserModal = null;

                if (browserModalElement && window.Modal) {
                    browserModal = new Modal(browserModalElement, {
                        backdrop: 'static',
                        closable: false
                    });
                }

                function getFocusableElements(container) {
                    return Array.from(container.querySelectorAll(
                        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
                    )).filter(el => !el.disabled && !el.getAttribute('aria-hidden'));
                }

                function enableFocusTrap(container, initialElement = null) {
                    if (!container) return;

                    disableFocusTrap();

                    previouslyFocusedElement = document.activeElement;
                    activeTrapContainer = container;

                    const focusable = getFocusableElements(container);
                    const firstFocusable = focusable[0];
                    const lastFocusable = focusable[focusable.length - 1];

                    setTimeout(() => {
                        if (initialElement instanceof HTMLElement) {
                            initialElement.focus();
                        } else {
                            firstFocusable?.focus();
                        }
                    }, 50);

                    container._focusTrapHandler = function (event) {
                        if (event.key !== 'Tab') return;

                        const elements = getFocusableElements(container);
                        const first = elements[0];
                        const last = elements[elements.length - 1];

                        if (!first || !last) {
                            event.preventDefault();
                            return;
                        }

                        if (event.shiftKey && document.activeElement === first) {
                            event.preventDefault();
                            last.focus();
                            return;
                        }

                        if (!event.shiftKey && document.activeElement === last) {
                            event.preventDefault();
                            first.focus();
                        }
                    };

                    container.addEventListener('keydown', container._focusTrapHandler);
                }

                function disableFocusTrap() {
                    if (activeTrapContainer?._focusTrapHandler) {
                        activeTrapContainer.removeEventListener('keydown', activeTrapContainer._focusTrapHandler);
                        delete activeTrapContainer._focusTrapHandler;
                    }

                    activeTrapContainer = null;
                }

                function restoreFocus() {
                    previouslyFocusedElement?.focus?.();
                    previouslyFocusedElement = null;
                }

                function lockPage() {
                    document.documentElement.classList.add('overflow-hidden');
                    document.body.classList.add('overflow-hidden');
                }

                function unlockPage() {
                    document.documentElement.classList.remove('overflow-hidden');
                    document.body.classList.remove('overflow-hidden');
                }

                function openBrowserModalIfNeeded() {
                    if (!browserModal || !browserModalElement || !browserAcceptButton) {
                        unlockPage();
                        restoreFocus();
                        return;
                    }

                    const lastSeen = parseInt(localStorage.getItem(STORAGE_KEY) || '0', 10);

                    if ((Date.now() - lastSeen) < ONE_HOUR) {
                        unlockPage();
                        restoreFocus();
                        return;
                    }

                    lockPage();
                    browserModal.show();

                    setTimeout(() => {
                        browserModalElement.setAttribute('aria-hidden', 'false');
                        enableFocusTrap(browserModalElement, document.getElementById('browser-info-title'));
                    }, 100);
                }

                browserAcceptButton?.addEventListener('click', async function () {
                    browserAcceptButton.disabled = true;

                    try {
                        const response = await fetch(browserAcceptButton.dataset.url, {
                            method: 'POST',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest',
                                'Content-Type': 'application/x-www-form-urlencoded'
                            },
                            body: new URLSearchParams({
                                _token: browserAcceptButton.dataset.csrf
                            })
                        });

                        if (!response.ok) {
                            throw new Error('Request failed');
                        }

                        localStorage.setItem(STORAGE_KEY, String(Date.now()));

                        disableFocusTrap();
                        browserModalElement.setAttribute('aria-hidden', 'true');
                        browserModal?.hide();

                        unlockPage();
                        restoreFocus();
                    } catch (error) {
                        console.error(error);
                        browserAcceptButton.disabled = false;
                        alert('{{ "Nie udało się zapisać potwierdzenia. Spróbuj ponownie."|trans }}');
                    }
                });

                if (cookieModal && cookieAcceptButton) {
                    lockPage();
                    enableFocusTrap(cookieModal, document.getElementById('cookie-consent-title'));

                    cookieAcceptButton.addEventListener('click', async function () {
                        cookieAcceptButton.disabled = true;

                        try {
                            const response = await fetch(cookieAcceptButton.dataset.acceptUrl, {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/x-www-form-urlencoded',
                                    'X-Requested-With': 'XMLHttpRequest'
                                },
                                body: new URLSearchParams({
                                    _token: cookieAcceptButton.dataset.token
                                })
                            });

                            if (!response.ok) {
                                throw new Error('Request failed');
                            }

                            window.location.reload();
                        } catch (error) {
                            console.error(error);
                            cookieAcceptButton.disabled = false;
                            alert('{{ "Nie udało się zapisać potwierdzenia. Spróbuj ponownie."|trans }}');
                        }
                    });

                    return;
                }

                openBrowserModalIfNeeded();
            });
        </script>

        {% block javascripts %}{% endblock %}
    </body>
</html>

