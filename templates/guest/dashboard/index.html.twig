{% extends 'guest/_layouts/after-login.html.twig' %}
{% block title %}{% trans %}Strona główna{% endtrans %} | Help VIZJA{% endblock %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}

{% block body %}
    <h1 id="page-title" class="mb-5 wrap-break-word text-3xl font-semibold">
        {% trans %}Pulpit{% endtrans %}
    </h1>
    <section class="py-10 rounded-2xl bg-zinc-50 dark:bg-zinc-800 {{ borderPrimary() }}">
        <div class="py-8 px-4 mx-auto max-w-screen-xl text-center sm:py-16 lg:px-6">
            <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-black dark:text-white">
                {% trans %}Najbardziej przydatne odnośniki{% endtrans %}
            </h2>

            <p class="text-black sm:text-xl dark:text-zinc-300">
                {% trans %}W tej sekcji znajdziesz ważne i często używane elementy strony{% endtrans %}
            </p>

            <div class="mt-8 lg:mt-12 space-y-8 md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-12 md:space-y-0">
                {% if is_granted('ROLE_STUDENT') %}
                    <div>
                        <svg class="mx-auto mb-4 w-12 h-12 text-primary-600 dark:text-yellow-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                             fill="currentColor" viewBox="0 0 24 24">
                            <path fill-rule="evenodd" d="M12 4a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm-2 9a4 4 0 0 0-4 4v1a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-1a4 4 0 0 0-4-4h-4Z" clip-rule="evenodd" />
                        </svg>

                        {% if app.user.studyMode and app.user.department and app.user.faculty and app.user.phone and app.user.albumNumber %}
                            <h3 class="mb-2 text-xl text-black font-bold dark:text-white">
                                <a href="{{ url('student_profile_update_data') }}"
                                   class="inline-flex items-center justify-center gap-1 text-primary-600 hover:text-primary-700 dark:text-yellow-400 dark:hover:text-yellow-400 hover:underline {{ focusPrimaryWithPadding() }}">
                                    <span>{% trans %}Zmień dane profilu{% endtrans %}</span>
                                    <span aria-hidden="true">›</span>
                                </a>
                            </h3>

                            <p class="mb-4 text-black dark:text-zinc-300">
                                {% trans %}Zmiany danych kontaktowych i osobowych należy aktualizować w profilu{% endtrans %}
                            </p>
                        {% else %}
                            <h3 class="mb-2 text-xl text-black font-bold dark:text-white">
                                <a href="{{ url('student_profile_update_data') }}"
                                   class="inline-flex items-center justify-center gap-1 text-primary-600 hover:text-primary-700 dark:text-yellow-400 dark:hover:text-yellow-400 hover:underline {{ focusPrimaryWithPadding() }}">
                                    <span>{% trans %}Uzupełnij swój profil{% endtrans %}</span>
                                    <span aria-hidden="true">›</span>
                                </a>
                            </h3>

                            <p class="mb-4 text-black dark:text-zinc-300">
                                {% trans %}Uzupełnij profil, aby łatwiej korzystać z platformy{% endtrans %}
                            </p>
                        {% endif %}
                    </div>

                    <div>
                        <svg class="mx-auto mb-4 w-12 h-12 text-primary-600 dark:text-yellow-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                            <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path>
                            <path fill-rule="evenodd"
                                  d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z"
                                  clip-rule="evenodd"></path>
                        </svg>

                        <h3 class="mb-2 text-xl text-black font-bold dark:text-white">
                            <a href="{{ url('student_choose_application_type') }}"
                               class="inline-flex items-center justify-center gap-1 text-primary-600 hover:text-primary-700 dark:text-yellow-400 dark:hover:text-yellow-400 hover:underline {{ focusPrimaryWithPadding() }}">
                                <span>{% trans %}Złóż nowy wniosek{% endtrans %}</span>
                                <span aria-hidden="true">›</span>
                            </a>
                        </h3>

                        <p class="mb-4 text-black dark:text-zinc-300">
                            {% trans %}Złóż nowy wniosek szybko i bez stresu{% endtrans %}
                        </p>
                    </div>
                {% endif %}

                <div>
                    <svg class="mx-auto mb-4 w-12 h-12 text-primary-600 dark:text-yellow-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                         fill="currentColor" viewBox="0 0 24 24">
                        <path d="m6 10.5237-2.27075.6386C3.29797 11.2836 3 11.677 3 12.125V20c0 .5523.44772 1 1 1h2V10.5237Zm12 0 2.2707.6386c.4313.1213.7293.5147.7293.9627V20c0 .5523-.4477 1-1 1h-2V10.5237Z" />
                        <path fill-rule="evenodd"
                              d="M12.5547 3.16795c-.3359-.22393-.7735-.22393-1.1094 0l-6.00002 4c-.45952.30635-.5837.92722-.27735 1.38675.30636.45953.92723.5837 1.38675.27735L8 7.86853V21h8V7.86853l1.4453.96352c.0143.00957.0289.01873.0435.02746.1597.09514.3364.14076.5112.1406.3228-.0003.6395-.15664.832-.44541.3064-.45953.1822-1.0804-.2773-1.38675l-6-4ZM10 12c0-.5523.4477-1 1-1h2c.5523 0 1 .4477 1 1s-.4477 1-1 1h-2c-.5523 0-1-.4477-1-1Zm1-4c-.5523 0-1 .44772-1 1s.4477 1 1 1h2c.5523 0 1-.44772 1-1s-.4477-1-1-1h-2Z"
                              clip-rule="evenodd" />
                    </svg>

                    <h3 class="mb-2 text-xl text-black font-bold dark:text-white">
                        <a href="{{ url('guest_office_registration_step_1') }}"
                           class="inline-flex items-center justify-center gap-1 text-primary-600 hover:text-primary-700 dark:text-yellow-400 dark:hover:text-yellow-400 hover:underline {{ focusPrimaryWithPadding() }}">
                            <span>{% trans %}Zarezerwuj wizytę w BON{% endtrans %}</span>
                            <span aria-hidden="true">›</span>
                        </a>
                    </h3>

                    <p class="mb-4 text-black dark:text-zinc-300">
                        {% trans %}Umów się na wizytę w Biurze ds. Osób z Niepełnosprawnościami online lub stacjonarnie{% endtrans %}
                    </p>
                </div>

                {% if is_granted('ROLE_GOSC') %}
                    <div>
                        <svg class="mx-auto mb-4 w-12 h-12 text-primary-600 dark:text-yellow-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                             fill="currentColor" viewBox="0 0 24 24">
                            <path fill-rule="evenodd"
                                  d="M6 5V4a1 1 0 1 1 2 0v1h3V4a1 1 0 1 1 2 0v1h3V4a1 1 0 1 1 2 0v1h1a2 2 0 0 1 2 2v2H3V7a2 2 0 0 1 2-2h1ZM3 19v-8h18v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Zm5-6a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2H8Z"
                                  clip-rule="evenodd" />
                        </svg>

                        <h3 class="mb-2 text-xl text-black font-bold dark:text-white">
                            <a href="{{ url('guest_registration_center_my_registrations') }}"
                               class="inline-flex items-center justify-center gap-1 text-primary-600 hover:text-primary-700 dark:text-yellow-400 dark:hover:text-yellow-400 hover:underline {{ focusPrimaryWithPadding() }}">
                                <span>{% trans %}Moje zapisy{% endtrans %}</span>
                                <span aria-hidden="true">›</span>
                            </a>
                        </h3>

                        <p class="mb-4 text-black dark:text-zinc-300">
                            {% trans %}Przejdź do listy wizyt, na które się zapisałeś/-aś{% endtrans %}
                        </p>
                    </div>
                {% endif %}

                {% if is_granted('ROLE_GOSC') %}
                    <div>
                        <svg class="mx-auto mb-4 h-12 w-12 shrink-0 text-primary-600 dark:text-yellow-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                            fill="currentColor" viewBox="0 0 24 24">
                            <path fill-rule="evenodd" d="M12 4a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm-2 9a4 4 0 0 0-4 4v1a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-1a4 4 0 0 0-4-4h-4Z" clip-rule="evenodd" />
                        </svg>

                        <h3 class="mb-2 wrap-break-word text-xl font-bold text-black dark:text-white">
                            <a href="{{ url('guest_profile_update_data') }}"
                                class="inline-flex max-w-full items-center justify-center gap-1 wrap-break-word text-primary-600 hover:text-primary-700 hover:underline dark:text-yellow-400 dark:hover:text-yellow-400 {{ focusPrimaryWithPadding() }}">
                                <span>{% trans %}Uzupełnij swój profil{% endtrans %}</span>
                                <span aria-hidden="true">›</span>
                            </a>
                        </h3>

                        <p class="mb-4 wrap-break-word text-black dark:text-zinc-300">
                            {% trans %}Uzupełnij profil, aby łatwiej korzystać z platformy{% endtrans %}
                        </p>
                    </div>
                {% endif %}

                <div>
                    <svg class="mx-auto mb-4 w-12 h-12 text-primary-600 dark:text-yellow-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                         fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd"
                              d="M2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10S2 17.523 2 12Zm9.008-3.018a1.502 1.502 0 0 1 2.522 1.159v.024a1.44 1.44 0 0 1-1.493 1.418 1 1 0 0 0-1.037.999V14a1 1 0 1 0 2 0v-.539a3.44 3.44 0 0 0 2.529-3.256 3.502 3.502 0 0 0-7-.255 1 1 0 0 0 2 .076c.014-.398.187-.774.48-1.044Zm.982 7.026a1 1 0 1 0 0 2H12a1 1 0 1 0 0-2h-.01Z"
                              clip-rule="evenodd" />
                    </svg>

                    <h3 class="mb-2 text-xl font-bold text-black dark:text-white">
                        <a href="{{ path('guest_faq') }}"
                           class="inline-flex items-center justify-center gap-1 text-primary-600 hover:text-primary-700 dark:text-yellow-400 dark:hover:text-yellow-400 hover:underline {{ focusPrimaryWithPadding() }}">
                            <span>{% trans %}Pytania i odpowiedzi{% endtrans %}</span>
                            <span aria-hidden="true">›</span>
                        </a>
                    </h3>

                    <p class="mb-4 text-black dark:text-zinc-300">
                        {% trans %}Sekcja najczęstszych pytań i odpowiedzi{% endtrans %}
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="mx-auto max-w-screen-xl px-4 py-8 sm:py-16 lg:px-6">
            <div class="grid space-y-8 lg:grid-cols-2 lg:gap-12 lg:space-y-0">
                <div class="min-w-0">
                    <h2 class="mb-4 wrap-break-word text-2xl font-extrabold tracking-tight text-gray-900 dark:text-white">
                        {% trans %}Poznaj Biuro ds. Osób z&nbsp;Niepełnosprawnościami{% endtrans %}
                    </h2>

                    <p class="mb-4 wrap-break-word text-black sm:text-xl dark:text-zinc-300">
                        {% trans %}Biuro ds. Osób z&nbsp;Niepełnosprawnościami wspiera studentów, pracowników i gości, którzy potrzebują dodatkowej pomocy.
                            Oferuje informacje, doradztwo oraz wsparcie w rozwiązywaniu codziennych trudności.{% endtrans %}
                    </p>

                    <a href="https://bon.vizja.pl/"
                       class="inline-flex max-w-full items-center wrap-break-word text-left font-medium text-primary-600 hover:text-primary-700 hover:underline sm:text-lg dark:text-yellow-400 dark:hover:text-yellow-400 {{ focusPrimaryWithPadding() }}">
                        <span class="wrap-break-word">{% trans %}Przejdź do strony Biura ds. Osób z&nbsp;Niepełnosprawnościami{% endtrans %}</span>
                        <svg class="ml-1 h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                        </svg>
                    </a>
                </div>

                <div class="min-w-0">
                    <a href="https://bon.vizja.pl/kontakt/"
                       class="mb-6 flex min-w-0 items-center justify-between gap-4 rounded-lg border-l-8 border-primary-600 bg-zinc-100 p-4 hover:text-primary-700 hover:underline dark:border-yellow-400 dark:bg-zinc-800 dark:hover:text-yellow-400 {{ borderPrimary() }} {{ focusPrimaryWithPadding() }}">
                        <div class="min-w-0 flex-1">
                            <span class="wrap-break-word text-xl font-semibold text-primary-600 dark:text-yellow-400">
                                {% trans %}Kontakt z Biurem ds. Osób z&nbsp;Niepełnosprawnościami{% endtrans %}
                            </span>
                        </div>
                        <svg class="h-6 w-6 shrink-0 text-primary-600 dark:text-yellow-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                                  clip-rule="evenodd"></path>
                        </svg>
                    </a>

                    <a href="https://bon.vizja.pl/aktualnosci/"
                       class="mb-6 flex min-w-0 items-center justify-between gap-4 rounded-lg border-l-8 border-primary-600 bg-zinc-100 p-4 hover:text-primary-700 hover:underline dark:border-yellow-400 dark:bg-zinc-800 dark:hover:text-yellow-400 {{ borderPrimary() }} {{ focusPrimaryWithPadding() }}">
                        <div class="min-w-0 flex-1">
                            <span class="wrap-break-word text-xl font-semibold text-primary-600 dark:text-yellow-400">
                                {% trans %}Aktualności{% endtrans %}
                            </span>
                        </div>
                        <svg class="h-6 w-6 shrink-0 text-primary-600 dark:text-yellow-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                                  clip-rule="evenodd"></path>
                        </svg>
                    </a>

                    <a href="https://bon.vizja.pl/dofinansowanie-z-programu-aktywny-samorzad-modul-ii/"
                       class="mb-6 flex min-w-0 items-center justify-between gap-4 rounded-lg border-l-8 border-primary-600 bg-zinc-100 p-4 hover:text-primary-700 hover:underline dark:border-yellow-400 dark:bg-zinc-800 dark:hover:text-yellow-400 {{ borderPrimary() }} {{ focusPrimaryWithPadding() }}">
                        <div class="min-w-0 flex-1">
                            <span class="wrap-break-word text-xl font-semibold text-primary-600 dark:text-yellow-400">
                                {% trans %}Aktywny Samorząd{% endtrans %}
                            </span>
                        </div>
                        <svg class="h-6 w-6 shrink-0 text-primary-600 dark:text-yellow-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                                  clip-rule="evenodd"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
