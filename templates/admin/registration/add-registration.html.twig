{% extends 'admin/_layouts/after-login.html.twig' %}
{% form_theme form 'student/_layouts/form-tailwind.html.twig' %}
{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}

{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}

    <script src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"></script>
{% endblock %}

{% block title %}{% trans %}Nowy termin - konsultacje{% endtrans %} | Admin Help VIZJA{% endblock %}


{% block body %}


    <section class="space-y-6 max-w-7xl mx-5">
        <header class="mb-6 flex items-start justify-between gap-4">
            {{ website_path([
                { label: 'Zapisy na konsultacje'|trans, route: 'admin_registration' },
                { label: 'Utwórz konsultację'|trans },
            ]) }}
        </header>

        <h1 id="page-title" class="font-semibold text-xl md:text-2xl lg:text-3xl">
            {% trans %}Utwórz konsultację{% endtrans %}
        </h1>

        {{ form_start(form, {
            attr: {
                class: 'space-y-8',
                novalidate: 'novalidate',
                role: 'form'
            }
        }) }}

        <fieldset class="space-y-8 border-0 p-0 m-0">
            <legend class="sr-only">
                {% trans %}Utwórz konsultacje{% endtrans %}
            </legend>

            {# ===== Podsumowanie błędów ===== #}
            {% set childErrors = [] %}
            {% for child in form %}
                {% if child.vars.errors|length %}
                    {% set childErrors = childErrors|merge([{
                        id: child.vars.id,
                        label: child.vars.label is not empty ? child.vars.label : child.vars.name|capitalize,
                        errors: child.vars.errors
                    }]) %}
                {% endif %}
            {% endfor %}

            {% if form_errors(form) is not empty or childErrors is not empty %}
                {% include '_partials/form-errors.html.twig' with { form: form, childErrors: childErrors } %}
            {% endif %}

            <div class="max-w-2xl space-y-4 w-full">

                {{ form_row(form.title) }}
                {{ form_row(form.language) }}

                <div class="max-w-56">
                    {{ form_row(form.capacity) }}
                </div>

                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                    {{ form_row(form.startsAt.date, {
                        label: 'Data rozpoczęcia cyklu',
                        attr: {
                            min: '1900-01-01',
                            max: '31.12.2099'
                        }
                    }) }}

                    {{ form_row(form.endsAt.date, {
                        label: 'Data zakończenia cyklu',
                        attr: {
                            min: '1900-01-01',
                            max: '2099-12-31'
                        }
                    }) }}

                    <div class="relative">
                        {{ form_row(form.startsAt.time, {
                            label: 'Godzina rozpoczęcia w każdy dzień'
                        }) }}
                        <svg class="pointer-events-none absolute right-3 top-[42px] h-6 w-6 text-primary-600 dark:text-yellow-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24"
                            height="24" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>

                    </div>

                    <div class="relative">
                        {{ form_row(form.endsAt.time, {
                            label: 'Godzina zakończenia w każdy dzień'
                        }) }}
                        <svg class="pointer-events-none absolute right-3 top-[42px] h-6 w-6 text-primary-600 dark:text-yellow-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24"
                            height="24" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                    </div>

                </div>
                <p
                    id="recurrence_help"
                    class="mb-2 text-base mt-3"
                >
                    {% trans %}W jednym cyklu można utworzyć maksymalnie 10 spotkań Teams (maksymalnie 10 dni w cyklu){% endtrans %}.
                </p>

                {{ form_row(form.recurrence, {
                    attr: {
                        'aria-describedby': 'recurrence_help'
                    }
                }) }}

                {{ form_row(form.description) }}
                {{ form_row(form.specialist) }}
            </div>

            <div class="gap-4 sm:flex sm:items-center">
                <a
                    class="{{ buttonSecondary() }} {{ focusPrimaryWithPadding() }}"
                    href="{{ url('admin_registration') }}"
                >
                    {% trans %}Wróć do listy{% endtrans %}
                </a>

                <button
                    class="cursor-pointer {{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}"
                    type="submit"
                >
                    {% trans %}Utwórz{% endtrans %}
                </button>
            </div>
        </fieldset>

        {{ form_end(form) }}
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const summary = document.getElementById('form_error_summary');
            if (summary) summary.focus();

            const starts = document.getElementById('{{ form.startsAt.vars.id }}');
            const ends = document.getElementById('{{ form.endsAt.vars.id }}');

            if (starts && ends) {
                const parseLocalDateTime = (value) => {
                    if (!value) return null;
                    const v = value.includes('T') ? value : value.replace(' ', 'T');
                    const d = new Date(v);
                    return isNaN(d.getTime()) ? null : d;
                };

                const formatForInput = (dateObj) => {
                    const pad = (n) => String(n).padStart(2, '0');
                    const y = dateObj.getFullYear();
                    const m = pad(dateObj.getMonth() + 1);
                    const d = pad(dateObj.getDate());
                    const hh = pad(dateObj.getHours());
                    const mm = pad(dateObj.getMinutes());
                    return `${ y }-${ m }-${ d }T${ hh }:${ mm }`;
                };

                const plusOneHour = (dateObj) => new Date(dateObj.getTime() + 50 * 60 * 1000);

                const maybeAutofillEnds = () => {
                    const s = parseLocalDateTime(starts.value);
                    if (!s) return;

                    const e = parseLocalDateTime(ends.value);

                    if (!e || e.getTime() <= s.getTime()) {
                        ends.value = formatForInput(plusOneHour(s));

                        ends.dispatchEvent(new Event('input', { bubbles: true }));
                        ends.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                };

                starts.addEventListener('change', maybeAutofillEnds);
                starts.addEventListener('input', maybeAutofillEnds);

                maybeAutofillEnds();
            }
        });

        document.addEventListener('click', function (e) {
            const t = e.target.closest('[data-focus-target]');
            if (!t) return;
            const id = t.getAttribute('data-focus-target');
            const field = document.getElementById(id);
            if (field) field.focus();
        });
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const input = document.getElementById('{{ form.capacity.vars.id }}');
            if (!input.value || Number(input.value) < 1) {
                input.value = 1;
            }
            input.addEventListener('input', () => {
                if (input.value === '' || Number(input.value) < 1) {
                    input.value = 1;
                }
            });
            input.addEventListener('keydown', (e) => {
                if (e.key === '-' || e.key === '+') {
                    e.preventDefault();
                }
            });
        });
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const dateInputs = document.querySelectorAll('input[type="date"]');

            dateInputs.forEach(input => {
                input.setAttribute('max', '2099-12-31');

                input.addEventListener('input', (e) => {
                    const value = e.target.value; // Format: YYYY-MM-DD

                    if (value) {
                        const parts = value.split('-');
                        const yearStr = parts[0];
                        const year = parseInt(yearStr, 10);

                        if ((yearStr.length === 4 && year > 2099) || yearStr.length > 4) {
                            parts[0] = '2099';
                            e.target.value = parts.join('-');
                        }
                    }
                });
            });
        });
    </script>

{% endblock %}
