{% extends 'admin/_layouts/after-login.html.twig' %}

{% block stylesheets %}{{ encore_entry_link_tags('admin_default') }}{% endblock %}
{% block javascripts %}{{ encore_entry_script_tags('admin_default') }}{% endblock %}
{% block title %}{% trans %}Ogłoszenia{% endtrans %} | Admin Help VIZJA{% endblock %}
{% block body %}
    <section class="p-4 rounded-lg">

        {{ website_path([
            { label: 'Ustawienia'|trans, route: 'admin_settings' },
            { label: 'Ogłoszenia'|trans },
        ]) }}

        <h1 class="text-xl font-semibold text-zinc-900 dark:text-white sm:text-2xl md:text-3xl">
            {% trans %}Najnowsze ogłoszenia{% endtrans %}
        </h1>

        <div class="mt-4 flex flex-col sm:flex-row sm:items-start gap-4">
            {% if announcements is not empty %}
                <a class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}" href="{{ url('admin_create_announcement') }}">
                    {% trans %}Utwórz nowe ogłsozenie{% endtrans %}
                </a>
            {% endif %}
            <a class="{{ buttonSecondary() }} {{ focusPrimaryWithPadding() }}" href="{{ url('admin_announcements_archive') }}">
                {% trans %}Archiwum{% endtrans %}
            </a>
        </div>

        {% if announcements is empty %}
            {{ empty_state(
                'Brak ważnych ogłoszeń'|trans,
                'Nie masz żadnych aktywnych ogłoszeń'|trans,
                {
                    action_route: 'admin_create_announcement',
                    action_route_params: {},
                    action_label: 'Utwórz nowe ogłoszenie'|trans
                }
            ) }}
        {% else %}
            <div class="mt-6 space-y-4">
                {% for a in announcements %}
                    <article class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm transition hover:shadow-md dark:border-zinc-700 dark:bg-zinc-800">
                        <header class="mb-3 flex items-start justify-between gap-3">
                            <h2 class="text-base font-semibold text-zinc-900 dark:text-white">
                                {{ a.title }}
                            </h2>
                        </header>

                        <dl class="space-y-2 text-sm">
                            <div class="flex items-center justify-between">
                                <dt class="text-zinc-500 dark:text-zinc-400">{% trans %}Data{% endtrans %}</dt>
                                <dd class="font-medium text-zinc-900 dark:text-zinc-100">
                                    {{ (a.startsAt ?? a.createdAt)|date('d.m.Y') }}
                                </dd>
                            </div>

                            <div class="flex items-center justify-between">
                                <dt class="text-zinc-500 dark:text-zinc-400">{% trans %}Godzina{% endtrans %}</dt>
                                <dd class="font-medium text-zinc-900 dark:text-zinc-100">
                                    {{ (a.startsAt ?? a.createdAt)|date('H:i') }}
                                </dd>
                            </div>

                            {% if a.expiresAt %}
                                <div class="flex items-center justify-between">
                                    <dt class="text-zinc-500 dark:text-zinc-400">{% trans %}Ważne do{% endtrans %}</dt>
                                    <dd class="font-medium text-zinc-900 dark:text-zinc-100">
                                        {{ a.expiresAt|date('d.m.Y H:i') }}
                                    </dd>
                                </div>
                            {% endif %}

                            {% if a.author is defined and a.author %}
                                <div class="flex items-center justify-between">
                                    <dt class="text-zinc-500 dark:text-zinc-400">{% trans %}Autor{% endtrans %}</dt>
                                    <dd class="font-medium text-zinc-900 dark:text-zinc-100">
                                        {{ a.author }}
                                    </dd>
                                </div>
                            {% endif %}
                        </dl>

                        {% set src = a.description is defined and a.description ? a.description : (a.content|default('')) %}

                        {% set rawText = src|striptags|trim %}

                        {% set snippet = (rawText|u).truncate(50, '…', false) %}

                        <p class="mt-4 text-sm text-zinc-700 dark:text-zinc-300">
                        <div class='font-semibold'>{% trans %}Snippet{% endtrans %}:</div>
                        {{ snippet }}...
                        </p>
                        <footer class="mt-4 flex flex-col sm:flex-row sm:items-center gap-4">

                            <a class="{{ buttonSecondary() }} {{ focusPrimaryWithPadding() }}" href="{{ url('admin_announcements_details', { id: a.id }) }}">
                                {% trans %}Czytaj więcej{% endtrans %}
                            </a>

                            <a class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}" href="{{ url('admin_update_announcement', { id: a.id }) }}">
                                {% trans %}Edytuj{% endtrans %}
                            </a>

                            {% if a.category is defined and a.category %}
                                <span class="rounded-full bg-zinc-100 px-2.5 py-1 text-xs font-medium text-zinc-700 dark:bg-zinc-700 dark:text-zinc-200">
                {{ a.category }}
              </span>
                            {% endif %}
                        </footer>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </section>

    {% include '_paginator/paginator.html.twig' with { pagination: pagination } %}
{% endblock %}
