{% extends 'admin/_layouts/after-login.html.twig' %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}

{% block title %}{% trans %}Szczegóły ogłoszenia{% endtrans %} | Admin Help VIZJA{% endblock %}

{% block body %}

    {{ website_path([
        { label: 'Ustawienia'|trans, route: 'admin_settings' },
        { label: 'Ogłoszenia'|trans, route: 'admin_announcement' },
        { label: 'Szczegóły ogłoszenia'|trans },
    ]) }}

    <section class="bg-white p-4 rounded-lg dark:bg-zinc-900">
        <div class="max-w-4xl">
            {# Główny header #}
            <header class="mb-4">
                <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-zinc-600 dark:text-zinc-300">
                    <div class="flex items-center gap-2">
                        <span
                            class="font-medium text-zinc-900 dark:text-white">{% trans %}Data publikacji{% endtrans %}</span>
                        <span>{{ (announcement.startsAt ?? announcement.createdAt)|date('d.m.Y H:i') }}</span>
                    </div>
                </div>
                <br>
                <div class="flex items-start justify-between gap-3">
                    <h1 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-white">
                        {{ announcement.title }}
                    </h1>
                </div>
                <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-zinc-600 dark:text-zinc-300">

                </div>
            </header>

            {# Karta treści #}
            <article
                class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm dark:border-zinc-700 dark:bg-zinc-800">
                <div class="prose max-w-none prose-zinc dark:prose-invert">
                    {# Treść ogłoszenia – HTML z bazy #}
                    {{ announcement.description|raw }}
                </div>

            </article>

        </div>
    </section>
{% endblock %}
