{% extends 'admin/_layouts/after-login.html.twig' %}
{% form_theme form 'student/_layouts/form-tailwind.html.twig' %}

{% block stylesheets %}{{ encore_entry_link_tags('admin_default') }}{% endblock %}
{% block javascripts %}{{ encore_entry_script_tags('admin_default') }}{% endblock %}
{% block title %}{% trans %}Dodawanie sprzętu{% endtrans %} | Admin Help VIZJA{% endblock %}
{% block body %}
    <h1 class="text-2xl md:text-3xl font-bold mb-4">{% trans %}Dodaj sprzęt{% endtrans %}</h1>

    {% if item is defined %}
        <div class="mb-4 text-sm text-zinc-600 dark:text-zinc-300">
            {% trans %}Kategoria{% endtrans %}: <span
                class="font-semibold text-zinc-900 dark:text-white">{{ item.value }} {{ type.type }}</span>
        </div>
    {% endif %}

    {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

    {# Błędy ogólne #}
    {{ form_errors(form) }}

    <div class="max-w-2xl w-full space-y-4">
        {{ form_row(form.serialNumber) }}
        {{ form_row(form.status) }}

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            {{ form_row(form.rentStart) }}
            {{ form_row(form.rentEnd) }}
        </div>

        {{ form_row(form.description) }}
    </div>

    <div class="max-w-2xl w-full">
        <div class="my-8 border-t border-zinc-300 dark:border-zinc-600"></div>

        <h2 class="mb-4 text-lg font-semibold text-zinc-900 dark:text-white">
            {% trans %}Przypisanie studenta{% endtrans %}
        </h2>

        <div class="space-y-2">
            <label
                for="student-search"
                class="block font-medium text-zinc-900 dark:text-white"
            >
                {% trans %}Wyszukaj studenta{% endtrans %}
            </label>

            <input
                id="student-search"
                type="text"
                placeholder="{% trans %}Wpisz imię, nazwisko lub email{% endtrans %}"
                class="w-full rounded-lg border-2 border-zinc-500 bg-white px-3 py-2
                   text-zinc-900 dark:border-zinc-500 dark:bg-zinc-800 dark:text-white
                   {{ focusPrimaryWithPadding() }}"
            >
        </div>

        <div
            id="students-field"
            class="mt-4 p-4 "
        >
            {{ form_row(form.student) }}
        </div>
    </div>

    <div class="mt-6 flex gap-2">
        <button class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}" type="submit">
            {% trans %}Zapisz{% endtrans %}
        </button>

        {% if item is defined %}
            <a
                class="{{ buttonSecondary() }} {{ focusPrimaryWithPadding() }}"
                href="{{ path('admin_inventory_items', { item: item.id, inventoryTypeId: type.id }) }}"
            >
                {% trans %}Anuluj{% endtrans %}
            </a>
        {% endif %}
    </div>

    {{ form_end(form) }}

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('student-search');
            const field = document.getElementById('students-field');

            if (!searchInput || !field) {
                return;
            }

            const select = field.querySelector('select');

            if (select) {
                const originalOptions = Array.from(select.options).map((option) => option.cloneNode(true));

                searchInput.addEventListener('input', () => {
                    const query = searchInput.value.trim().toLowerCase();

                    select.innerHTML = '';

                    originalOptions.forEach((option) => {
                        if (!query || option.text.toLowerCase().includes(query)) {
                            select.appendChild(option.cloneNode(true));
                        }
                    });
                });

                return;
            }

            const items = Array.from(field.querySelectorAll('label')).map((label) => {
                const wrapper = label.closest('div') || label.parentElement;

                return {
                    wrapper,
                    text: label.textContent.trim().toLowerCase()
                };
            });

            searchInput.addEventListener('input', () => {
                const query = searchInput.value.trim().toLowerCase();

                items.forEach((item) => {
                    item.wrapper.style.display = !query || item.text.includes(query) ? '' : 'none';
                });
            });
        });
    </script>
{% endblock %}
