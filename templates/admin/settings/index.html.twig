{% extends 'admin/_layouts/after-login.html.twig' %}

{% block stylesheets %}{{ encore_entry_link_tags('admin_default') }}{% endblock %}
{% block javascripts %}{{ encore_entry_script_tags('admin_default') }}{% endblock %}
{% block title %}{% trans %}Ustawienia strony{% endtrans %} | Admin Help VIZJA{% endblock %}

{% block body %}
    <section class="p-5 rounded-2xl">
        <header class="mb-6 flex items-start justify-between gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-white">{% trans %}Ustawienia strony{% endtrans %}</h1>
                <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-300">{% trans %}Zarządzaj modułami i konfiguracją systemu{% endtrans %}</p>
            </div>
        </header>

        {# Szybkie wyszukiwanie #}
        <div class="mb-6 max-w-200">
            <label
                for="settings-search"
                class="mb-2 block font-semibold text-zinc-900 dark:text-white"
            >
                {% trans %}Szukaj modułu{% endtrans %}
            </label>

            <div class="relative">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                    <svg
                        class="h-5 w-5 text-zinc-500 dark:text-zinc-400"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        fill="none"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke="currentColor"
                            stroke-linecap="round"
                            stroke-width="2"
                            d="m21 21-3.5-3.5M17 10a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"
                        />
                    </svg>
                </div>

                <input
                    id="settings-search"
                    type="search"
                    placeholder="{% trans %}Wpisz nazwę modułu…{% endtrans %}"
                    class="w-full rounded-xl
                   border-2 border-zinc-500 dark:border-zinc-400
                   bg-white dark:bg-zinc-900
                   py-2.5 pl-10 pr-4
                   text-sm text-zinc-900 dark:text-white
                   placeholder-zinc-500 dark:placeholder-zinc-400
                   {{ focusPrimaryWithPadding() }}"
                    oninput="filterCards(this.value)"
                >
            </div>
        </div>

        <div id="settings-grid" class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">

            {# Pracownicy #}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_users') }}"
                    data-card
                    class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true"
                                xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                                viewBox="0 0 24 24">
                                <path fill-rule="evenodd"
                                    d="M12 6a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Zm-1.5 8a4 4 0 0 0-4 4 2 2 0 0 0 2 2h7a2 2 0 0 0 2-2 4 4 0 0 0-4-4h-3Zm6.82-3.096a5.51 5.51 0 0 0-2.797-6.293 3.5 3.5 0 1 1 2.796 6.292ZM19.5 18h.5a2 2 0 0 0 2-2 4 4 0 0 0-4-4h-1.1a5.503 5.503 0 0 1-.471.762A5.998 5.998 0 0 1 19.5 18ZM4 7.5a3.5 3.5 0 0 1 5.477-2.889 5.5 5.5 0 0 0-2.796 6.293A3.501 3.501 0 0 1 4 7.5ZM7.1 12H6a4 4 0 0 0-4 4 2 2 0 0 0 2 2h.5a5.998 5.998 0 0 1 3.071-5.238A5.505 5.505 0 0 1 7.1 12Z"
                                    clip-rule="evenodd"></path>
                            </svg>

                        </div>

                        <div>
                            <h2 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Pracownicy{% endtrans %}
                            </h2>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Wszyscy pracownicy i ich uprawnienia{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>
            {% endif %}

            {# Studenci #}
            {% if is_granted('ROLE_EMPLOYEE') %}
                <a href="{{ path('admin_students') }}"
                    data-card
                    class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true"
                                xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                                viewBox="0 0 24 24">
                                <path
                                    d="M12.4472 2.10557c-.2815-.14076-.6129-.14076-.8944 0L5.90482 4.92956l.37762.11119c.01131.00333.02257.00687.03376.0106L12 6.94594l5.6808-1.89361.3927-.13363-5.6263-2.81313ZM5 10V6.74803l.70053.20628L7 7.38747V10c0 .5523-.44772 1-1 1s-1-.4477-1-1Zm3-1c0-.42413.06601-.83285.18832-1.21643l3.49538 1.16514c.2053.06842.4272.06842.6325 0l3.4955-1.16514C15.934 8.16715 16 8.57587 16 9c0 2.2091-1.7909 4-4 4-2.20914 0-4-1.7909-4-4Z"></path>
                                <path
                                    d="M14.2996 13.2767c.2332-.2289.5636-.3294.8847-.2692C17.379 13.4191 19 15.4884 19 17.6488v2.1525c0 1.2289-1.0315 2.1428-2.2 2.1428H7.2c-1.16849 0-2.2-.9139-2.2-2.1428v-2.1525c0-2.1409 1.59079-4.1893 3.75163-4.6288.32214-.0655.65589.0315.89274.2595l2.34883 2.2606 2.3064-2.2634Z"></path>
                            </svg>

                        </div>

                        <div>
                            <h2 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Studenci{% endtrans %}
                            </h2>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Lista wszystkich studentów z możliwością blokady konta{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>
            {% endif %}

            {# Słowniki #}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_dictionaries') }}"
                    data-card
                    class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true"
                                xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                                viewBox="0 0 24 24">
                                <path fill-rule="evenodd"
                                    d="M2 6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6Zm4.996 2a1 1 0 0 0 0 2h.01a1 1 0 1 0 0-2h-.01ZM11 8a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-6Zm-4.004 3a1 1 0 1 0 0 2h.01a1 1 0 1 0 0-2h-.01ZM11 11a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-6Zm-4.004 3a1 1 0 1 0 0 2h.01a1 1 0 1 0 0-2h-.01ZM11 14a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-6Z"
                                    clip-rule="evenodd"></path>
                            </svg>

                        </div>

                        <div>
                            <h2 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Słownik{% endtrans %}
                            </h2>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Nazwy kierunków, wydziałów, typy dokumentów{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>
            {% endif %}

            {# Ogłoszenia #}
            {% if is_granted('ROLE_EMPLOYEE') %}
                <a href="{{ path('admin_announcement') }}"
                    data-card
                    class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true"
                                xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                                viewBox="0 0 24 24">
                                <path fill-rule="evenodd"
                                    d="M18.458 3.11A1 1 0 0 1 19 4v16a1 1 0 0 1-1.581.814L12 16.944V7.056l5.419-3.87a1 1 0 0 1 1.039-.076ZM22 12c0 1.48-.804 2.773-2 3.465v-6.93c1.196.692 2 1.984 2 3.465ZM10 8H4a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h6V8Zm0 9H5v3a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-3Z"
                                    clip-rule="evenodd" />
                            </svg>

                        </div>

                        <div>
                            <h2 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Ogłoszenia{% endtrans %}
                            </h2>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Publikacja ogłoszeń{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>
            {% endif %}

            {# Inwentaryzacja #}
            {% if is_granted('ROLE_EMPLOYEE') %}
                <a href="{{ path('admin_inventory') }}"
                    data-card
                    class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true"
                                xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                                viewBox="0 0 24 24">
                                <path fill-rule="evenodd"
                                    d="M12 8a1 1 0 0 0-1 1v10H9a1 1 0 1 0 0 2h11a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-8Zm4 10a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z"
                                    clip-rule="evenodd" />
                                <path fill-rule="evenodd"
                                    d="M5 3a2 2 0 0 0-2 2v6h6V9a3 3 0 0 1 3-3h8c.35 0 .687.06 1 .17V5a2 2 0 0 0-2-2H5Zm4 10H3v2a2 2 0 0 0 2 2h4v-4Z"
                                    clip-rule="evenodd" />
                            </svg>

                        </div>

                        <div>
                            <h2 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Inwentaryzacja{% endtrans %}
                            </h2>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Inwentaryzacja sprzętu{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>
            {% endif %}


            {# Ankieta oceny aplikacji #}
            {% if is_granted('ROLE_EMPLOYEE') %}
                <a href="{{ path('admin_questionnaire') }}"
                    data-card
                    class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true"
                                xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                                viewBox="0 0 24 24">
                                <path
                                    d="M13.5 2c-.178 0-.356.013-.492.022l-.074.005a1 1 0 0 0-.934.998V11a1 1 0 0 0 1 1h7.975a1 1 0 0 0 .998-.934l.005-.074A7.04 7.04 0 0 0 22 10.5 8.5 8.5 0 0 0 13.5 2Z" />
                                <path
                                    d="M11 6.025a1 1 0 0 0-1.065-.998 8.5 8.5 0 1 0 9.038 9.039A1 1 0 0 0 17.975 13H11V6.025Z" />
                            </svg>

                        </div>

                        <div>
                            <h2 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Ankieta oceny aplikacji{% endtrans %}
                            </h2>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Ankieta wypełniona przez studentów{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>
            {% endif %}

            {# FAQ #}
            {% if is_granted('ROLE_EMPLOYEE') %}
                <a href="{{ path('admin_faq') }}"
                    data-card
                    class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true"
                                xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
                                viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9.529 9.988a2.502 2.502 0 1 1 5 .191A2.441 2.441 0 0 1 12 12.582V14m-.01 3.008H12M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                            </svg>

                        </div>

                        <div>
                            <h2 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}FAQ{% endtrans %}
                            </h2>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Najczęściej zadawane pytania{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>
            {% endif %}

        </div>
    </section>

    <script>
        function normalizeText(text) {
            return text
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '');
        }

        function filterCards(query = '') {
            const normalizedQuery = normalizeText(query.trim());
            const cards = document.querySelectorAll('#settings-grid [data-card]');

            cards.forEach((card) => {
                const cardText = normalizeText(card.innerText);
                card.classList.toggle('hidden', !cardText.includes(normalizedQuery));
            });
        }
    </script>
{% endblock %}
