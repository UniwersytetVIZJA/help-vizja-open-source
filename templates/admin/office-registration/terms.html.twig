{% extends 'admin/_layouts/after-login.html.twig' %}

{% block stylesheets %}{{ encore_entry_link_tags('admin_default') }}{% endblock %}
{% block javascripts %}{{ encore_entry_script_tags('admin_default') }}{% endblock %}
{% block title %}{% trans %}Wizyty w biurze BON{% endtrans %} | Admin Help VIZJA{% endblock %}
{% block body %}
    <section class="space-y-8">
        <h1 id="page-title" class="font-semibold text-xl md:text-2xl lg:text-3xl">
            {% trans %}Wizyty w biurze BON{% endtrans %}
        </h1>

        <div>
            <a class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}" href="{{ url('admin_office_registration_terms_create') }}">
                {% trans %}Dodaj nowy termin{% endtrans %}
            </a>
        </div>

        <div class="pt-5">
            <div class="gap-4 grid grid-cols-1 md:grid-cols-2 md:gap-6">
                <div>
                    <h2 class="text-lg sm:text-xl md:text-2xl font-semibold text-zinc-900 dark:text-white mb-4 lg:mb-8">
                        {% trans %}Kalendarz wizyt w BON{% endtrans %}
                    </h2>

                    <div class="w-full min-w-0 max-w-full">
                        <div class="flex gap-x-4 items-center justify-between mb-6 w-full sm:gap-x-6">
                            <div class="flex items-center justify-end flex-1">
                                <button type="button" aria-label="Poprzedni miesiąc" id="cal-prev"
                                    class="border border-default h-10 rounded-xl shrink-0 text-center text-lg w-10 hover:opacity-80 {{ focusPrimaryWithPadding() }}">
                                    &laquo;
                                </button>
                            </div>
                            <div class="flex flex-col items-center gap-y-1 shrink-0 sm:mx-10">
                                <div id="cal-title" class="font-semibold text-heading capitalize text-center text-md sm:text-lg truncate max-w-full"></div>
                                <button type="button" aria-label="Przejdź do najbliższego wolnego terminu" id="cal-next-available"
                                    class="px-2.5 sm:px-3 py-1 text-sm min-[w-200px] border border-default rounded-xl hover:opacity-80 {{ focusPrimaryWithPadding() }}">
                                    {% trans %}Najbliższy wolny termin{% endtrans %}
                                </button>
                            </div>
                            <div class="flex items-center justify-start flex-1">
                                <button type="button" aria-label="Następny miesiąc" id="cal-next"
                                    class="border border-default h-10 rounded-xl shrink-0 text-center text-lg w-10 hover:opacity-80 {{ focusPrimaryWithPadding() }}">
                                    &raquo;
                                </button>
                            </div>
                        </div>

                        <div class="w-full">
                            <div class="inline-block w-full">
                                <div class="grid grid-cols-7 sm:gap-2 text-center text-xs opacity-70 mb-2 select-none">
                                    <div>{% trans %}Pn{% endtrans %}</div>
                                    <div>{% trans %}Wt{% endtrans %}</div>
                                    <div>{% trans %}Śr{% endtrans %}</div>
                                    <div>{% trans %}Cz{% endtrans %}</div>
                                    <div>{% trans %}Pt{% endtrans %}</div>
                                    <div>{% trans %}So{% endtrans %}</div>
                                    <div>{% trans %}Nd{% endtrans %}</div>
                                </div>
                                <div id="cal-grid" class="grid grid-cols-7 gap-1 sm:gap-2 md:gap-3"></div>
                            </div>
                        </div>
                    </div>

                    <p class="mt-4 text-sm">
                        {% trans %}Wybierz dzień, aby zobaczyć dostępne godziny{% endtrans %}
                    </p>

                    <p class="font-semibold mt-4 text-sm">
                        {% trans %}Legenda{% endtrans %}:
                    </p>

                    <div class="mt-8 flex flex-col gap-4 text-sm text-zinc-900 dark:text-white">
                        <div class="flex items-center gap-8">
                            <span class="ml-5 h-3 w-3 rounded-full bg-emerald-700 shrink-0"></span>
                            <span>{% trans %}Potwierdzone wizyty{% endtrans %}</span>
                        </div>

                        <div class="flex items-center gap-8">
                            <span class="ml-5 w-0 h-0 border-l-[7px] border-l-transparent border-r-[7px] border-r-transparent border-t-[14px] border-t-orange-500 shrink-0"></span>
                            <span>{% trans %}Oczekuje na potwierdzenie{% endtrans %}</span>
                        </div>

                        <div class="flex items-center gap-8">
                            <span class="ml-4 h-[4px] w-8 rounded-full bg-black dark:bg-white shrink-0"></span>
                            <span>{% trans %}Dostępne terminy{% endtrans %}</span>
                        </div>
                    </div>
                </div>

                <div>
                    <h3
                        id="available-hours-title"
                        tabindex="-1"
                        class="rounded-lg text-xl font-semibold text-zinc-900 dark:text-white mb-4 {{ focusPrimaryWithPadding() }}"
                    >
                        {% trans %}Terminy wizyt:{% endtrans %}
                        <span id="selected-date"></span>
                    </h3>

                    <label class="sr-only">
                        {% trans %}Wybierz godzinę{% endtrans %}
                    </label>

                    <ul id="timetable" class="grid w-fit grid-cols-1 gap-2 mt-5">
                        <li class="text-center text-sm opacity-70">
                            {% trans %}Wybierz datę, aby zobaczyć godziny{% endtrans %}
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <script>
        (function () {
            const slotBtnClass = {{ buttonSecondary()|json_encode|raw }};
            const apiBaseUrl = {{ path('admin_office_terms')|json_encode|raw }};
            const monthDaysUrl = {{ path('admin_office_terms_days')|json_encode|raw }};
            const editUrlTemplate = {{ path('admin_office_registration_active_reg', { id: '___ID___' })|json_encode|raw }};

            function pad2(n) {
                return String(n).padStart(2, '0');
            }

            function ymd(d) {
                return `${ d.getFullYear() }-${ pad2(d.getMonth() + 1) }-${ pad2(d.getDate()) }`;
            }

            function startOffsetMonday(dateObj) {
                const jsDay = dateObj.getDay();
                return (jsDay + 6) % 7;
            }

            function setHumanDate(output, dateObj) {
                output.textContent = dateObj.toLocaleDateString('pl-PL', {
                    weekday: 'long',
                    day: '2-digit',
                    month: 'long',
                    year: 'numeric'
                });
            }

            function focusAvailableHoursTitle() {
                const heading = document.getElementById('available-hours-title');

                if (!heading) {
                    return;
                }

                heading.setAttribute('tabindex', '-1');

                window.setTimeout(() => {
                    heading.focus({ preventScroll: true });

                    heading.scrollIntoView({
                        behavior: 'smooth',
                        block: 'center',
                        inline: 'nearest'
                    });
                }, 50);
            }

            function toEditUrl(id) {
                return editUrlTemplate.replace('___ID___', encodeURIComponent(String(id)));
            }

            let monthWithSlots = new Set();
            let monthWithAvailable = new Set();
            let monthWithPending = new Set();
            let monthWithConfirmed = new Set();

            async function fetchMonthDays(viewDate) {
                const month = `${ viewDate.getFullYear() }-${ pad2(viewDate.getMonth() + 1) }`;

                try {
                    const res = await fetch(`${ monthDaysUrl }?month=${ encodeURIComponent(month) }`, {
                        headers: { Accept: 'application/json' },
                        credentials: 'same-origin'
                    });

                    if (!res.ok) {
                        throw new Error('HTTP ' + res.status);
                    }

                    const json = await res.json();

                    monthWithSlots = new Set(json.days || []);
                    monthWithAvailable = new Set(json.daysAvailable || []);
                    monthWithPending = new Set(json.daysPending || []);
                    monthWithConfirmed = new Set(json.daysConfirmed || []);
                } catch (e) {
                    console.error('MONTH DAYS ERROR:', e);

                    monthWithSlots = new Set();
                    monthWithAvailable = new Set();
                    monthWithPending = new Set();
                    monthWithConfirmed = new Set();
                }
            }

            async function fetchSlots(dateStr, timetable) {
                timetable.innerHTML =
                    '<li class="col-span-2 text-center text-sm opacity-70">Ładowanie godzin...</li>';

                try {
                    const res = await fetch(`${ apiBaseUrl }?date=${ encodeURIComponent(dateStr) }`, {
                        headers: { Accept: 'application/json' },
                        credentials: 'same-origin'
                    });

                    const text = await res.text();

                    if (!res.ok) {
                        throw new Error('HTTP ' + res.status);
                    }

                    const json = JSON.parse(text);

                    renderSlots(json.slots || [], timetable);
                } catch (e) {
                    console.error('FETCH ERROR:', e);

                    timetable.innerHTML =
                        '<li class="col-span-2 text-center text-sm text-red-500">Błąd ładowania godzin</li>';
                }
            }

            function renderSlots(slots, timetable) {
                timetable.innerHTML = '';

                if (!slots.length) {
                    timetable.innerHTML =
                        '<li class="col-span-2 text-center text-sm opacity-70">Brak dodanych godzin</li>';
                    return;
                }

                for (const slot of slots) {
                    const li = document.createElement('li');

                    const isPending = slot.registered === null;
                    const isConfirmed = Number(slot.registered) === 1;

                    const slotClass = isConfirmed
                        ? 'block w-full rounded-xl border-2 bg-emerald-700 px-4 py-3 text-center font-semibold text-white transition hover:bg-emerald-800 hover:border-emerald-600 dark:bg-emerald-500 dark:hover:bg-emerald-600 dark:border-emerald-400 focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:focus-visible:outline-yellow-400 focus-visible:ring-3 focus-visible:ring-blue-600 dark:focus-visible:ring-yellow-400 ring-offset-3 ring-offset-white dark:ring-offset-zinc-900'
                        : isPending
                            ? 'block w-full rounded-xl border-2 bg-orange-700 px-4 py-3 text-center font-semibold text-white dark:text-black transition hover:bg-orange-800 hover:border-orange-600 dark:bg-orange-500 dark:hover:bg-orange-600 dark:border-orange-400 focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:focus-visible:outline-yellow-400 focus-visible:ring-3 focus-visible:ring-blue-600 dark:focus-visible:ring-yellow-400 ring-offset-3 ring-offset-white dark:ring-offset-zinc-900'
                            : 'block w-full rounded-xl border-2 border-zinc-600 bg-white px-4 py-3 text-center font-semibold text-zinc-900 transition hover:bg-zinc-100 hover:border-zinc-300 dark:bg-zinc-700 dark:border-zinc-300 dark:text-white dark:hover:bg-zinc-800 focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:focus-visible:outline-yellow-400 focus-visible:ring-3 focus-visible:ring-blue-600 dark:focus-visible:ring-yellow-400 ring-offset-3 ring-offset-white dark:ring-offset-zinc-900';

                    li.innerHTML = `
                    <a href="${ toEditUrl(slot.id) }" class="${ slotClass }">
                        <span class="block text-base">${ slot.time }</span>
                        <span class="mt-1 block text-base font-normal">
                            ${
                        isConfirmed
                            ? 'Potwierdzona wizyta'
                            : isPending
                                ? 'Oczekuje na potwierdzenie'
                                : 'Podgląd terminu'
                    }
                        </span>
                    </a>
                `;

                    timetable.appendChild(li);
                }
            }

            function buildCalendarGrid(gridEl, titleEl, viewDate, selectedDateStr, onPick) {
                gridEl.innerHTML = '';

                const year = viewDate.getFullYear();
                const month = viewDate.getMonth();

                const first = new Date(year, month, 1);
                const daysInMonth = new Date(year, month + 1, 0).getDate();
                const offset = startOffsetMonday(first);

                titleEl.textContent = first.toLocaleDateString('pl-PL', {
                    month: 'long',
                    year: 'numeric'
                });

                for (let i = 0; i < offset; i++) {
                    const div = document.createElement('div');
                    div.className = 'h-12 w-12';
                    gridEl.appendChild(div);
                }

                for (let day = 1; day <= daysInMonth; day++) {
                    const d = new Date(year, month, day);
                    const dStr = ymd(d);

                    const isSelected = dStr === selectedDateStr;
                    const hasSlots = monthWithSlots.has(dStr);
                    const hasPending = monthWithPending.has(dStr);
                    const hasConfirmed = monthWithConfirmed.has(dStr);
                    const hasAvailable = monthWithAvailable.has(dStr);

                    const btn = document.createElement('button');

                    btn.type = 'button';
                    btn.dataset.date = dStr;

                    let ariaLabel = d.toLocaleDateString('pl-PL', {
                        weekday: 'long',
                        day: 'numeric',
                        month: 'long',
                        year: 'numeric'
                    });

                    const statuses = [];

                    if (hasPending) {
                        statuses.push('są wizyty oczekujące na potwierdzenie');
                    }

                    if (hasConfirmed) {
                        statuses.push('są potwierdzone wizyty');
                    }

                    if (hasAvailable) {
                        statuses.push('są dostępne terminy');
                    }

                    ariaLabel += statuses.length ? ', ' + statuses.join(', ') : ', brak terminów';

                    btn.setAttribute('aria-label', ariaLabel);
                    btn.setAttribute('aria-pressed', isSelected ? 'true' : 'false');

                    let classes = [
                        'group',
                        'inline-block',
                        'h-12',
                        'w-full',
                        'relative rounded-xl text-sm transition',
                        'hover:opacity-90',
                        {{ focusPrimaryWithPadding()|json_encode|raw }}
                    ];

                    const now = new Date();
                    now.setHours(0, 0, 0, 0);

                    const cellDate = new Date(d);
                    cellDate.setHours(0, 0, 0, 0);

                    const isPast = cellDate < now;
                    const isDisabled = isPast || !hasSlots;

                    if (isDisabled) {
                        btn.disabled = true;
                        btn.setAttribute('aria-disabled', 'true');

                        classes.push(
                            'group',
                            'bg-zinc-100',
                            'text-black',
                            'dark:bg-zinc-800',
                            'dark:text-white',
                            'cursor-not-allowed'
                        );
                    } else if (isSelected) {
                        classes.push(
                            'border-3',
                            'border-blue-600',
                            'bg-blue-50',
                            'text-black',
                            'font-semibold',
                            'dark:bg-yellow-700',
                            'dark:border-yellow-300',
                            'dark:text-white'
                        );
                    } else if (hasPending) {
                        classes.push(
                            'group',
                            'border-3',
                            'bg-white',
                            'text-black',
                            'border-orange-400',
                            'font-medium',
                            'dark:bg-zinc-700',
                            'dark:text-white'
                        );
                    } else if (hasConfirmed) {
                        classes.push(
                            'group',
                            'border-3',
                            'bg-white',
                            'text-black',
                            'border-emerald-600',
                            'font-medium',
                            'dark:border-emerald-300',
                            'dark:bg-zinc-700',
                            'dark:text-white'
                        )
                        ;
                    } else {
                        classes.push(
                            'bg-white',
                            'border-3',
                            'border-zinc-500',
                            'text-black',
                            'font-medium',
                            'dark:bg-zinc-700',
                            'dark:border-zinc-300',
                            'dark:text-white'
                        );
                    }

                    btn.className = classes.join(' ');

                    btn.innerHTML = `
                    <span class="relative flex items-center justify-center w-full h-full overflow-hidden rounded-xl">
                        ${ day }

                       ${
                        hasPending && !isDisabled
                            ? `<span class="absolute top-1 right-1 w-0 h-0 border-l-[7px] border-l-transparent border-r-[7px] border-r-transparent border-t-[12px] ${
                                isSelected
                                    ? 'border-t-black dark:border-t-white'
                                    : 'border-t-orange-500'
                            }"></span>`
                            : ''
                    }

                        ${
                        hasConfirmed && !isDisabled
                            ? `<span class="absolute top-1 left-1 h-2.5 w-2.5 rounded-full ${
                                isSelected
                                    ? 'bg-black dark:bg-white'
                                    : 'bg-emerald-700 dark:bg-emerald-300'
                            }"></span>`
                            : ''
                    }

                        ${
                        hasAvailable && !isDisabled
                            ? `<span class="absolute bottom-1 left-1/2 h-[3px] w-7 -translate-x-1/2 rounded-full bg-black dark:bg-white"></span>`
                            : ''
                    }
                    </span>
                `;

                    if (!isDisabled) {
                        btn.addEventListener('click', () => onPick(dStr, true));
                    }

                    gridEl.appendChild(btn);
                }
            }

            function initOfficeSlots() {
                const root = document.querySelector('section.space-y-8');

                if (!root || root.dataset.officeSlotsInit === '1') {
                    return;
                }

                root.dataset.officeSlotsInit = '1';

                const output = document.getElementById('selected-date');
                const timetable = document.getElementById('timetable');
                const grid = document.getElementById('cal-grid');
                const title = document.getElementById('cal-title');
                const prev = document.getElementById('cal-prev');
                const next = document.getElementById('cal-next');
                const nextAvailableBtn = document.getElementById('cal-next-available');

                if (!output || !timetable || !grid || !title || !prev || !next || !nextAvailableBtn) {
                    return;
                }

                let selected = new Date();
                let view = new Date(selected.getFullYear(), selected.getMonth(), 1);

                async function applyPickedDate(dateStr, shouldMoveFocus = true) {
                    if (!dateStr) {
                        return;
                    }

                    const d = new Date(dateStr + 'T00:00:00');

                    selected = d;

                    setHumanDate(output, d);

                    buildCalendarGrid(grid, title, view, dateStr, applyPickedDate);

                    await fetchSlots(dateStr, timetable);

                    if (shouldMoveFocus) {
                        focusAvailableHoursTitle();
                    }
                }

                async function render() {
                    await fetchMonthDays(view);

                    buildCalendarGrid(grid, title, view, ymd(selected), applyPickedDate);
                }

                async function findNextAvailableDate() {
                    const now = new Date();
                    now.setHours(0, 0, 0, 0);

                    let searchView = new Date(now.getFullYear(), now.getMonth(), 1);

                    for (let i = 0; i < 24; i++) {
                        await fetchMonthDays(searchView);

                        const availableDates = [...monthWithSlots]
                            .filter((dateStr) => {
                                const date = new Date(dateStr + 'T00:00:00');
                                return date >= now;
                            })
                            .sort();

                        if (availableDates.length) {
                            return availableDates[0];
                        }

                        searchView = new Date(
                            searchView.getFullYear(),
                            searchView.getMonth() + 1,
                            1
                        );
                    }

                    return null;
                }

                prev.addEventListener('click', async () => {
                    view = new Date(view.getFullYear(), view.getMonth() - 1, 1);
                    await render();
                });

                next.addEventListener('click', async () => {
                    view = new Date(view.getFullYear(), view.getMonth() + 1, 1);
                    await render();
                });

                nextAvailableBtn.addEventListener('click', async () => {
                    const nextDate = await findNextAvailableDate();

                    if (!nextDate) {
                        return;
                    }

                    const d = new Date(nextDate + 'T00:00:00');

                    selected = d;
                    view = new Date(d.getFullYear(), d.getMonth(), 1);

                    await render();
                    await applyPickedDate(nextDate, true);
                });

                (async () => {
                    await render();

                    await applyPickedDate(ymd(selected), false);
                })();
            }

            document.addEventListener('DOMContentLoaded', initOfficeSlots);
            document.addEventListener('turbo:load', initOfficeSlots);
        })();
    </script>
{% endblock %}
