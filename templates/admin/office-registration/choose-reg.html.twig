{% extends 'admin/_layouts/after-login.html.twig' %}

{% block stylesheets %}{{ encore_entry_link_tags('admin_default') }}{% endblock %}
{% block javascripts %}{{ encore_entry_script_tags('admin_default') }}{% endblock %}
{% block title %}{% trans %}Wizyty w biurze BON{% endtrans %}{% endblock %}
{% block body %}

    <section class="p-5 rounded-2xl">

        {{ website_path([
            { label: 'Centrum wizyt'|trans, route: 'admin_office_registration_index' },
            { label: 'Wizyty'|trans },
        ]) }}
        <header class="mb-6 flex items-start justify-between gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-white">{% trans %}Wizyty w biurze BON{% endtrans %}</h1>
            </div>
        </header>

        <div id="settings-grid" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {% if is_granted('ROLE_ADMIN') %}
                {% set icon_users %}
                    <svg class="h-6 w-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd"
                            d="M12 6a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Zm-1.5 8a4 4 0 0 0-4 4 2 2 0 0 0 2 2h7a2 2 0 0 0 2-2 4 4 0 0 0-4-4h-3Zm6.82-3.096a5.51 5.51 0 0 0-2.797-6.293 3.5 3.5 0 1 1 2.796 6.292ZM19.5 18h.5a2 2 0 0 0 2-2 4 4 0 0 0-4-4h-1.1a5.503 5.503 0 0 1-.471.762A5.998 5.998 0 0 1 19.5 18ZM4 7.5a3.5 3.5 0 0 1 5.477-2.889 5.5 5.5 0 0 0-2.796 6.293A3.501 3.501 0 0 1 4 7.5ZM7.1 12H6a4 4 0 0 0-4 4 2 2 0 0 0 2 2h.5a5.998 5.998 0 0 1 3.071-5.238A5.505 5.505 0 0 1 7.1 12Z"
                            clip-rule="evenodd"></path>
                    </svg>
                {% endset %}

                {{ dashboard_link_card(
                    'Najbliższe wizyty'|trans,
                    'Sprawdź najbliższe aktywne zapisy'|trans,
                    'admin_office_registration_active_reg',
                    {},
                    {
                        icon_html: icon_users,
                        accent: 'amber',
                        open_label: 'Otwórz'|trans
                    }
                ) }}
            {% endif %}



            {% if is_granted('ROLE_EMPLOYEE') %}
                {% set dictionary_icon %}
                    <svg class="w-6 h-6 text-zinc-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd"
                            d="M18.458 3.11A1 1 0 0 1 19 4v16a1 1 0 0 1-1.581.814L12 16.944V7.056l5.419-3.87a1 1 0 0 1 1.039-.076ZM22 12c0 1.48-.804 2.773-2 3.465v-6.93c1.196.692 2 1.984 2 3.465ZM10 8H4a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h6V8Zm0 9H5v3a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-3Z"
                            clip-rule="evenodd" />
                    </svg>
                {% endset %}

                {{ dashboard_link_card(
                    'Archiwum'|trans,
                    'Sprawdź archiwalne wizyty'|trans,
                    'admin_office_registration_archive_reg',
                    {},
                    { accent: 'amber', icon_html: dictionary_icon, open_label: 'Otwórz'|trans }
                ) }}
            {% endif %}
        </div>
    </section>

{% endblock %}
