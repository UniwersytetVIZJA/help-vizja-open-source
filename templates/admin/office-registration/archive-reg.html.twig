{% extends 'admin/_layouts/after-login.html.twig' %}

{% block stylesheets %}{{ encore_entry_link_tags('admin_default') }}{% endblock %}
{% block javascripts %}{{ encore_entry_script_tags('admin_default') }}{% endblock %}
{% block title %}{% trans %}Najbliższe wizyty{% endtrans %}{% endblock %}
{% block body %}

    <section class="py-8 antialiased dark:bg-zinc-900 md:py-16">
        {{ website_path([
            { label: 'Centrum wizyt'|trans, route: 'admin_office_registration_index' },
            { label: 'Wizyty'|trans, route: 'admin_office_registration_choose_reg' },
            { label: 'Archiwalne wizyty'|trans },
        ]) }}

        <div class="mx-auto max-w-screen-xl px-4 2xl:px-0">
            <h2 class="mb-4 text-xl font-semibold text-zinc-900 dark:text-white sm:text-2xl md:mb-8">{% trans %}Archiwalne wizyty w BON{% endtrans %}</h2>
            <div class="gap-8 lg:flex">
                <!-- Right content -->
                <div class="w-full">

                    <div class="py-4">
                        <a class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}"
                            href="{{ path('admin_office_registration_active_reg') }}">
                            {% trans %}Aktywne wizyty{% endtrans %}
                        </a>
                    </div>
                    {% for registration in registrations %}
                        <!-- Cards -->
                        <div class="mb-4 rounded-lg bg-white p-4 dark:bg-zinc-800 {{ borderPrimary() }}">
                            <div class="items-start justify-between border-b border-zinc-100 pb-4 dark:border-zinc-700 sm:flex">
                                <div class="mb-4 sm:mb-0">
                                    <h3 class="dark:text-gry-400 mb-2 text-zinc-500">
                                        {% trans %}Imię i nazwisko{% endtrans %}:
                                        <a href="#" class="font-medium text-zinc-900 hover:underline dark:text-white">{{ registration.student.firstName }} {{ registration.student.lastName }}</a>
                                    </h3>
                                    <h3 class="dark:text-gry-400 mb-2 text-zinc-500">
                                        {% trans %}Adres e-mail{% endtrans %}:
                                        <a href="#" class="font-medium text-zinc-900 hover:underline dark:text-white">{{ registration.student.email }}</a>
                                    </h3>
                                </div>
                            </div>
                            <div class="mb-4 items-center sm:flex sm:flex-wrap xl:flex">
                                <dl class="mt-4 flex items-center text-zinc-500 dark:text-zinc-400 sm:me-8">
                                    <dt class="me-2 font-medium text-zinc-900 dark:text-white">{% trans %}Data{% endtrans %}:</dt>
                                    <dd>{{ registration.term|date('d.m.Y') }}</dd>
                                </dl>
                                <dl class="mt-4 flex items-center text-zinc-500 dark:text-zinc-400 sm:me-8">
                                    <dt class="me-2 font-medium text-zinc-900 dark:text-white">{% trans %}Godzina{% endtrans %}:</dt>
                                    <dd>{{ registration.term|date('H:i') }}</dd>
                                </dl>
                            </div>
                        </div>
                    {% endfor %}

                </div>
            </div>
        </div>
    </section>
{% endblock %}
