{% extends 'admin/_layouts/after-login.html.twig' %}
{% form_theme form 'student/_layouts/form-tailwind.html.twig' %}

{% block stylesheets %}{{ encore_entry_link_tags('admin_default') }}{% endblock %}
{% block javascripts %}{{ encore_entry_script_tags('admin_default') }}{% endblock %}
{% block title %}
    {% trans %}Edycja terminu{% endtrans %}: {{ registration.startAt|date('d.m.Y') }}, {{ registration.startAt|date('H:i') }} - {{ registration.endAt|date('H:i') }} | Admin Help VIZJA
{% endblock %}
{% block body %}


    <section class="py-8 antialiased md:py-16">
        <header class="mb-6 flex items-start justify-between gap-4">
            {{ website_path([
                { label: 'Wizyty w biurze'|trans, route: 'admin_office_registration_terms' },
                { label: 'Szczegóły zapisu'|trans, route: 'admin_office_registration_active_reg', route_params: { id: registration.id } },
                { label: 'Edytuj termin'|trans },
            ]) }}
        </header>

        <h1 class="text-xl font-semibold text-zinc-900 dark:text-white sm:text-2xl md:text-3xl mb-5">
            {% trans %}Edytuj termin{% endtrans %}
        </h1>

        {{ form_start(form, {
            attr: {
                class: 'space-y-8',
                novalidate: 'novalidate',
                role: 'form',
                'aria-describedby': 'form_instructions'
            }
        }) }}
        {# ===== Podsumowanie błędów ===== #}
        {% set childErrors = [] %}
        {% for child in form %}
            {% if child.vars.errors|length %}
                {% set childErrors = childErrors|merge([{
                    id: child.vars.id,
                    label: child.vars.label is not empty ? child.vars.label : child.vars.name|capitalize,
                    errors: child.vars.errors
                }]) %}
            {% endif %}
        {% endfor %}
        {% if form_errors(form) is not empty or childErrors is not empty %}
            {% include '_partials/form-errors.html.twig' with { form: form, childErrors: childErrors } %}
        {% endif %}
        <div class="max-w-2xl space-y-4 w-full">

            {{ form_row(form.startAt) }}
            {{ form_row(form.endAt) }}

        </div>

        <div class="gap-4 sm:flex sm:items-center">
            <button class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}" type="submit">
                {% trans %}Zapisz{% endtrans %}
            </button>

            {{ form_end(form) }}

            {% set formId  = 'block-student-form-' ~ registration.id %}
            {% set modalId = 'blockStudentModal-' ~ registration.id %}

            <form
                id="{{ formId }}"
                method="post"
                action="{{ url('admin_office_registration_terms_delete', {id: registration.id}) }}"
            >
                <input type="hidden" name="_token" value="{{ csrf_token('delete_office_term_' ~ registration.id) }}">

                <button
                    type="button"
                    data-modal-target="{{ modalId }}"
                    data-modal-toggle="{{ modalId }}"
                    class="{{ buttonDelete() }} {{ focusPrimaryWithPadding() }}"
                >
                    <strong>{% trans %}Usuń termin{% endtrans %}</strong>
                </button>
            </form>

            {% include 'admin/_components/confirm-modal.html.twig' with {
                modalId: modalId,
                formId: formId,
                title: 'Usunąć termin?',
                message: 'Czy na pewno chcesz usunąć termin?',
                warningText: 'Nie będzie można przywrócić usuniętego terminu.',
                confirmLabel: 'Usuń',
                cancelLabel: 'Wróć'
            } %}
        </div>
    </section>
{% endblock %}
