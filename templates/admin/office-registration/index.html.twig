{% extends 'admin/_layouts/after-login.html.twig' %}

{% block stylesheets %}{{ encore_entry_link_tags('admin_default') }}{% endblock %}
{% block javascripts %}{{ encore_entry_script_tags('admin_default') }}{% endblock %}
{% block title %}{% trans %}Wizyty w biurze BON{% endtrans %}{% endblock %}
{% block body %}

    <section class="p-5 rounded-2xl">


        <header class="mb-6 flex items-start justify-between gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-white">{% trans %}Wizyty w biurze BON{% endtrans %}</h1>
            </div>
        </header>

        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
            <a href="{{ path('admin_office_registration_terms') }}"
               class="cursor-pointer rounded-2xl border-2 border-zinc-200 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimary() }}">
                <div class="flex items-start gap-4">
                    <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                        <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 10h16m-8-3V4M7 7V4m10 3V4M5 20h14a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1Zm3-7h.01v.01H8V13Zm4 0h.01v.01H12V13Zm4 0h.01v.01H16V13Zm-8 4h.01v.01H8V17Zm4 0h.01v.01H12V17Zm4 0h.01v.01H16V17Z"/>
                        </svg>

                    </div>

                    <div>
                        <h3 class="font-semibold text-zinc-900 dark:text-white">
                            {% trans %}Udostępnione terminy{% endtrans %}
                        </h3>
                        <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                            {% trans %}Sprawdź wszysktie terminy lub dodaj nowy{% endtrans %}
                        </p>
                    </div>
                </div>
            </a>

            <a href="{{ url('admin_office_registration_calendar') }}"
               class="cursor-pointer rounded-2xl border-2 border-zinc-200 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimary() }}">
                <div class="flex items-start gap-4">
                    <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                        <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="M16 19h4a1 1 0 0 0 1-1v-1a3 3 0 0 0-3-3h-2m-2.236-4a3 3 0 1 0 0-4M3 18v-1a3 3 0 0 1 3-3h4a3 3 0 0 1 3 3v1a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1Zm8-10a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                        </svg>

                    </div>

                    <div>
                        <h3 class="font-semibold text-zinc-900 dark:text-white">
                            {% trans %}Wizyty{% endtrans %}
                        </h3>
                        <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                            {% trans %}Przeglądaj i zarządzaj wizytami{% endtrans %}
                        </p>
                    </div>
                </div>
            </a>
        </div>
    </section>

{% endblock %}
