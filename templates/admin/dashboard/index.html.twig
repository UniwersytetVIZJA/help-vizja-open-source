{% extends 'admin/_layouts/after-login.html.twig' %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}

{% block title %}{% trans %}Pulpit{% endtrans %} | Admin Help VIZJA{% endblock %}

{% block body %}
    <div id="main-content" class="space-y-8">

        <section class="rounded-2xl bg-white p-6 shadow-sm dark:bg-zinc-800">
            <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
                <div class="space-y-3">
                    <h1 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-3xl">
                        {% trans %}Panel pracowniczy Help VIZJA{% endtrans %}
                    </h1>

                    <p class="max-w-3xl text-base leading-7 text-zinc-600 dark:text-zinc-300">
                        {% trans %}Zarządzaj terminami wizyt, wnioskami, wizytami oraz obsługą studentów z jednego miejsca.{% endtrans %}
                    </p>
                </div>
            </div>
        </section>

        <section aria-labelledby="quick-actions-heading" class="space-y-4">
            <h2 id="quick-actions-heading" class="text-xl font-semibold text-zinc-900 dark:text-white">
                {% trans %}Szybkie akcje{% endtrans %}
            </h2>

            <div class="grid gap-8 sm:grid-cols-2 xl:grid-cols-4">
                <a href="{{ path('admin_registration') }}"
                   class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true"
                                 xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
                                 viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M4 10h16m-8-3V4M7 7V4m10 3V4M5 20h14a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1Zm3-7h.01v.01H8V13Zm4 0h.01v.01H12V13Zm4 0h.01v.01H16V13Zm-8 4h.01v.01H8V17Zm4 0h.01v.01H12V17Zm4 0h.01v.01H16V17Z"/>
                            </svg>

                        </div>

                        <div>
                            <h3 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Zapisy na konsultacje{% endtrans %}
                            </h3>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Przeglądaj i edytuj terminy wizyt{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>

                <a href="{{ url('admin_office_registration_terms') }}"
                   class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true"
                                 xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
                                 viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M8 20v-9l-4 1.125V20h4Zm0 0h8m-8 0V6.66667M16 20v-9l4 1.125V20h-4Zm0 0V6.66667M18 8l-6-4-6 4m5 1h2m-2 3h2"/>
                            </svg>

                        </div>

                        <div>
                            <h3 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Wizyty w biurze{% endtrans %}
                            </h3>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Przeglądaj i zarządzaj wizytami w biurze{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>

                <a href="{{ url('admin_applications') }}"
                   class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true"
                                 xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
                                 viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M15 4h3a1 1 0 0 1 1 1v15a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h3m0 3h6m-5-4v4h4V3h-4Z"/>
                            </svg>

                        </div>

                        <div>
                            <h3 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Wnioski{% endtrans %}
                            </h3>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Przeglądaj wnioski przesłane przez studentów{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>

                <a href="{{ url('admin_announcement') }}"
                   class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true"
                                 xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
                                 viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M7.556 8.5h8m-8 3.5H12m7.111-7H4.89a.896.896 0 0 0-.629.256.868.868 0 0 0-.26.619v9.25c0 .232.094.455.26.619A.896.896 0 0 0 4.89 16H9l3 4 3-4h4.111a.896.896 0 0 0 .629-.256.868.868 0 0 0 .26-.619v-9.25a.868.868 0 0 0-.26-.619.896.896 0 0 0-.63-.256Z"/>
                            </svg>

                        </div>

                        <div>
                            <h3 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Ogłoszenia{% endtrans %}
                            </h3>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Zarządzaj ogłoszeniami udostępnionymi dla studentów{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>
                <a href="{{ url('admin_inventory') }}"
                   class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">
                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true"
                                 xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"
                                 viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M7.556 8.5h8m-8 3.5H12m7.111-7H4.89a.896.896 0 0 0-.629.256.868.868 0 0 0-.26.619v9.25c0 .232.094.455.26.619A.896.896 0 0 0 4.89 16H9l3 4 3-4h4.111a.896.896 0 0 0 .629-.256.868.868 0 0 0 .26-.619v-9.25a.868.868 0 0 0-.26-.619.896.896 0 0 0-.63-.256Z"/>
                            </svg>

                        </div>

                        <div>
                            <h3 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Inwentaryzacja sprzętu{% endtrans %}
                            </h3>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Zarządzaj sprzętem{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        </section>
    </div>
{% endblock %}
