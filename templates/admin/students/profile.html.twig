{% extends 'admin/_layouts/after-login.html.twig' %}
{% block title %}{% trans %}Profil studenta{% endtrans %}{% endblock %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}

{% block body %}
    {{ website_path([
        { label: 'Ustawienia'|trans, route: 'admin_settings' },
        { label: 'Studenci'|trans, route: 'admin_students' },
        { label: 'Profil studenta'|trans },
    ]) }}
    <section class="py-8 antialiased md:py-8">
        <div class="mx-auto max-w-screen-xl px-4 2xl:px-0">

            <h1 class="mb-4 text-xl font-semibold text-zinc-900 dark:text-white sm:text-2xl md:mb-6">{% trans %}Profil studenta{% endtrans %}</h1>
            <div class="flex flex-col gap-4">
                <div class="col-span-4 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-700 dark:bg-zinc-800 md:p-6">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
                        <div class="flex h-20 w-20 shrink-0 items-center justify-center overflow-hidden rounded-lg bg-blue-600 text-sm font-semibold text-white dark:bg-yellow-400 dark:text-zinc-900">
            <span class="avatar-initials hidden">
                {{ student.initials }}
            </span>

                            <img
                                src="{{ path('admin_ms_user_photo', { upn: student.email }) }}"
                                alt="{% trans %}Zdjęcie profilowe{% endtrans %}"
                                class="h-20 w-20 object-cover"
                                onerror="this.style.display='none'; this.parentElement.querySelector('.avatar-initials').classList.remove('hidden');"
                            >
                        </div>

                        <div class="min-w-0">
                            {% if 'ROLE_STUDENT' in student.roles %}
                                <span class="mb-2 inline-block rounded bg-primary-100 px-2.5 py-0.5 text-xs font-medium text-primary-800 dark:bg-primary-900 dark:text-primary-300">
                    Student
                </span>
                            {% elseif 'ROLE_PRACOWNIK' in student.roles %}
                                <span class="mb-2 inline-block rounded bg-primary-100 px-2.5 py-0.5 text-xs font-medium text-primary-800 dark:bg-primary-900 dark:text-primary-300">
                    Pracownik
                </span>
                            {% endif %}

                            <h2 class="break-words text-xl font-bold leading-tight text-zinc-900 dark:text-white sm:text-2xl">
                                {{ student.firstName }} {{ student.lastName }}
                            </h2>

                            <p class="mt-1 break-words text-sm text-zinc-500 dark:text-zinc-400">
                                {{ student.email }}
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-span-4 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-700 dark:bg-zinc-800 md:col-span-2 md:p-6 xl:col-span-1">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                        <h2 class="min-w-0 break-words text-xl font-bold text-zinc-900 dark:text-white">
                            {% trans %}Dane kontaktowe{% endtrans %}
                        </h2>

                        <a
                            class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }} inline-flex w-full items-center justify-center text-center sm:w-auto sm:max-w-[280px]"
                            href="{{ url('admin_students_profile_update_contact', { id: student.id }) }}"
                        >
                            {% trans %}Edytuj{% endtrans %}
                        </a>
                    </div>

                    <p class="mt-4 break-words text-zinc-500 dark:text-zinc-400">
                        {% trans %}Adres e-mail{% endtrans %}:
                        <strong class="text-zinc-900 dark:text-white">{{ student.email }}</strong>
                    </p>

                    <p class="mt-2 break-words text-zinc-500 dark:text-zinc-400">
                        {% trans %}Numer telefonu{% endtrans %}:
                        <strong class="text-zinc-900 dark:text-white">
                            +{{ student.phone ? student.phone.countryCode : '-' }} {{ student.phone ? student.phone.nationalNumber : '-' }}
                        </strong>
                    </p>
                </div>

                <div class="col-span-4 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-700 dark:bg-zinc-800 md:col-span-2 md:p-6 xl:col-span-1">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                        <h2 class="min-w-0 break-words text-xl font-bold text-zinc-900 dark:text-white">
                            {% trans %}Dane o studiach{% endtrans %}
                        </h2>

                        <a
                            class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }} inline-flex w-full items-center justify-center text-center sm:w-auto sm:max-w-[280px]"
                            href="{{ url('admin_student_profile_update_data_verbis', { id: student.id }) }}"
                        >
                            {% trans %}Zaktualizuj{% endtrans %}
                        </a>
                    </div>

                    <p class="mt-4 break-words text-zinc-500 dark:text-zinc-400">
                        {% trans %}Numer albumu{% endtrans %}:
                        <strong class="text-zinc-900 dark:text-white">{{ student.albumNumber }}</strong>
                    </p>

                    <p class="break-words text-zinc-500 dark:text-zinc-400">
                        {% trans %}Wydział{% endtrans %}:
                        <strong class="text-zinc-900 dark:text-white">{{ student.wydzialVerbis }}</strong>
                    </p>

                    <p class="break-words text-zinc-500 dark:text-zinc-400">
                        {% trans %}Kierunek{% endtrans %}:
                        <strong class="text-zinc-900 dark:text-white">{{ student.kierunekVerbis }}</strong>
                    </p>

                    <p class="break-words text-zinc-500 dark:text-zinc-400">
                        {% trans %}Tryb{% endtrans %}:
                        <strong class="text-zinc-900 dark:text-white">
                            {% if student.trybZajecVerbis is not empty %}
                                {% if student.trybZajecVerbis is same as 'Z' %}
                                    Zaoczny
                                {% else %}
                                    Stacjonarny
                                {% endif %}
                            {% endif %}
                        </strong>
                    </p>

                    <p class="break-words text-zinc-500 dark:text-zinc-400">
                        {% trans %}Rok{% endtrans %}:
                        <strong class="text-zinc-900 dark:text-white">{{ student.rokStudiowVerbis }}</strong>
                    </p>

                    <p class="break-words text-zinc-500 dark:text-zinc-400">
                        {% trans %}Semestr{% endtrans %}:
                        <strong class="text-zinc-900 dark:text-white">{{ student.semestrVerbis }}</strong>
                    </p>
                </div>

                <div class="col-span-4 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-700 dark:bg-zinc-800 md:col-span-2 md:p-6 xl:col-span-1">
                    <div>
                        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                            <h2 class="min-w-0 break-words text-xl font-bold text-zinc-900 dark:text-white">
                                {% trans %}Karta adaptacji{% endtrans %}
                            </h2>

                            <a
                                class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }} inline-flex w-full items-center justify-center text-center sm:w-auto sm:max-w-[280px]"
                                href="{{ url('admin_students_profile_update_adaptation_card', { id: student.id }) }}"
                            >
                                {% trans %}Edytuj{% endtrans %}
                            </a>
                        </div>

                        <div class="mt-4 space-y-2">
                            <p class="break-words text-zinc-500 dark:text-zinc-400">
                                {% trans %}Okres ważności{% endtrans %}:
                                <strong class="text-zinc-900 dark:text-white">
                                    {{ student.adaptationExpiration ? student.adaptationExpiration.value : '-' }}
                                </strong>
                            </p>
                        </div>

                        <p class="mt-4 break-words text-zinc-500 dark:text-zinc-400">
                            {% trans %}Rodzaj adaptacji{% endtrans %}:
                        </p>

                        <div class="space-y-1 text-left text-zinc-900 dark:text-white">
                            {% for item in student.adaptationType %}
                                <p class="break-words">- {{ item.value }}</p>
                            {% else %}
                                <p>-</p>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <div class="col-span-4 space-y-4 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-700 dark:bg-zinc-800 md:col-span-2 md:p-6">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                        <h2 class="min-w-0 break-words text-xl font-bold text-zinc-900 dark:text-white">
                            {% trans %}Orzeczenie o niepełnosprawności{% endtrans %}
                        </h2>

                        <a
                            class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }} inline-flex w-full items-center justify-center text-center sm:w-auto sm:max-w-[280px]"
                            href="{{ url('admin_student_profile_update_disability_verbis', { id: student.id }) }}"
                        >
                            {% trans %}Zaktualizuj{% endtrans %}
                        </a>
                    </div>

                    <p class="break-words text-zinc-500 dark:text-zinc-400">
                        {% trans %}Kraj wydania{% endtrans %}:
                        <strong class="text-zinc-900 dark:text-white">{{ student.disabilityCountry }}</strong>
                    </p>

                    <p class="break-words text-zinc-500 dark:text-zinc-400">
                        {% trans %}Rodzaj{% endtrans %}:
                        <strong class="text-zinc-900 dark:text-white">
                            {{ student.disabilityType|default([])|join(', ') }}
                        </strong>
                    </p>

                    <p class="break-words text-zinc-500 dark:text-zinc-400">
                        {% trans %}Stopień{% endtrans %}:
                        <strong class="text-zinc-900 dark:text-white">{{ student.disabilityDegree }}</strong>
                    </p>

                    <p class="break-words text-zinc-500 dark:text-zinc-400">
                        {% trans %}Data ważności{% endtrans %}:
                        <strong class="text-zinc-900 dark:text-white">
                            {% if student.disabilityExpiration %}
                                {{ student.disabilityExpiration|date('d.m.Y') }}
                            {% else %}
                                {% trans %}Wydano na stałe{% endtrans %}
                            {% endif %}
                        </strong>
                    </p>
                </div>

                <div class="col-span-4 space-y-4 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-700 dark:bg-zinc-800 md:col-span-2 md:p-6">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                        <h2 class="min-w-0 break-words text-xl font-bold text-zinc-900 dark:text-white">
                            {% trans %}Szczególne potrzeby{% endtrans %}
                        </h2>

                        <a
                            class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }} inline-flex w-full items-center justify-center text-center sm:w-auto sm:max-w-[280px]"
                            href="{{ url('admin_students_profile_update_special_needs', { id: student.id }) }}"
                        >
                            {% trans %}Edytuj{% endtrans %}
                        </a>
                    </div>

                    <div class="min-w-0 space-y-2">
                        <p class="break-words whitespace-pre-line text-zinc-500 dark:text-zinc-400">
                            {{ student.specialNeeds ?: '-' }}
                        </p>
                    </div>
                </div>
                <div class="col-span-4 divide-y divide-[#71718C] overflow-hidden rounded-lg border border-[#71718C] bg-white shadow-sm dark:divide-[#71718C] dark:border-[#71718C] dark:bg-zinc-800">
                    <div class="space-y-4 p-4">
                        <h2 class="text-lg font-semibold text-zinc-900 dark:text-white">
                            {% trans %}Historia wniosków{% endtrans %}
                        </h2>
                    </div>

                    <div class="relative overflow-x-auto">
                        <table class="w-full divide-y divide-[#71718C] text-left text-sm text-zinc-900 dark:divide-[#71718C] dark:text-white">
                            <caption class="sr-only">
                                {% trans %}Historia wniosków{% endtrans %}
                            </caption>

                            <thead class="bg-zinc-50 text-sm font-semibold text-zinc-900 dark:bg-zinc-700 dark:text-white">
                                <tr class="border-b border-[#71718C]">
                                    <th scope="col" class="p-4 font-semibold">{% trans %}Lp.{% endtrans %}</th>
                                    <th scope="col" class="px-4 py-3 font-semibold">{% trans %}Data utworzenia{% endtrans %}</th>
                                    <th scope="col" class="px-4 py-3 font-semibold">{% trans %}Numer wniosku{% endtrans %}</th>
                                    <th scope="col" class="px-4 py-3 font-semibold">{% trans %}Numer albumu{% endtrans %}</th>
                                    <th scope="col" class="px-4 py-3 font-semibold">{% trans %}Imię i nazwisko{% endtrans %}</th>
                                    <th scope="col" class="px-4 py-3 font-semibold">{% trans %}Rodzaj wniosku{% endtrans %}</th>
                                    <th scope="col" class="px-4 py-3 font-semibold">{% trans %}Status{% endtrans %}</th>
                                    <th scope="col" class="px-4 py-3 font-semibold whitespace-nowrap">{% trans %}Akcje{% endtrans %}</th>
                                </tr>
                            </thead>

                            <tbody class="divide-y divide-[#71718C]">
                                {% for application in pagination %}
                                    <tr
                                        class="cursor-pointer border-b border-[#71718C] hover:bg-zinc-100 dark:hover:bg-zinc-700"
                                        onclick="window.location='{{ path('admin_applications_applicationDetails', { applicationId: application.id }) }}'"
                                    >
                                        <td class="w-4 px-4 py-3 dark:text-white">
                                            <div class="flex items-center">
                                <span class="px-4 py-2 whitespace-nowrap">
                                    {{ loop.index }}.
                                </span>
                                            </div>
                                        </td>

                                        <td class="px-4 py-2 whitespace-nowrap">
                                            {{ application.createdAt | date('d.m.Y H:i') }}
                                        </td>

                                        <td class="px-4 py-2 whitespace-nowrap dark:text-white">
                                            {{ application.applicationNumber }}
                                        </td>

                                        <td class="px-4 py-2 whitespace-nowrap dark:text-white">
                                            {{ application.albumNumber }}
                                        </td>

                                        <td class="px-4 py-2 whitespace-nowrap dark:text-white">
                                            {{ application.student.firstName }} {{ application.student.lastName }}
                                        </td>

                                        <td class="px-4 py-2">
                                            <div class="inline-flex items-center bg-primary-100 text-primary-800 text-xs font-medium px-2 py-0.5 rounded dark:bg-primary-900 dark:text-primary-300">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 mr-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                                    <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
                                                    <path fill-rule="evenodd" clip-rule="evenodd"
                                                        d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" />
                                                </svg>

                                                {% if app.request.locale == 'pl' %}
                                                    {{ application.type.value }}
                                                {% else %}
                                                    {{ application.type.valueEnglish }}
                                                {% endif %}
                                            </div>
                                        </td>

                                        {% set statusColors = {
                                            'Nowy': 'bg-zinc-300',
                                            'W trakcie': 'bg-yellow-500',
                                            'Do poprawy': 'bg-red-500',
                                            'Odrzucony': 'bg-red-500',
                                            'Zaakceptowany': 'bg-green-500',
                                        } %}

                                        <td class="px-4 py-2 text-zinc-900 whitespace-nowrap dark:text-white">
                                            <div class="flex items-center">
                                                <div class="w-3 h-3 mr-2 border rounded-full {{ statusColors[application.status]|default('bg-zinc-500') }}"></div>
                                                {{ application.status }}
                                            </div>
                                        </td>

                                        <td class="px-4 py-2 whitespace-nowrap">
                                            <a
                                                class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}"
                                                href="{{ url('admin_applications_applicationDetails', { applicationId: application.id }) }}"
                                            >
                                                {% trans %}Podgląd{% endtrans %}
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    <div class="px-4 py-4">
                        <nav class="flex flex-col items-start justify-between space-y-3 md:flex-row md:items-center md:space-y-0" aria-label="{% trans %}Nawigacja tabeli{% endtrans %}">
                            {% include '_paginator/paginator.html.twig' with { pagination: pagination } %}
                        </nav>
                    </div>
                </div>
            </div>
            <!-- Main modal -->
            <div id="deleteOrderModal" tabindex="-1" aria-hidden="true"
                class="fixed left-0 right-0 top-0 z-50 hidden h-modal w-full items-center justify-center overflow-y-auto overflow-x-hidden md:inset-0 md:h-full">
                <div class="relative h-full w-full max-w-md p-4 md:h-auto">
                    <!-- Modal content -->
                    <div class="relative rounded-lg bg-white p-4 text-center shadow dark:bg-zinc-800 sm:p-5">
                        <button type="button"
                            class="absolute right-2.5 top-2.5 ml-auto inline-flex items-center rounded-lg bg-transparent p-1.5 text-sm text-zinc-400 hover:bg-zinc-200 hover:text-zinc-900 dark:hover:bg-zinc-600 dark:hover:text-white"
                            data-modal-toggle="deleteOrderModal">
                            <svg aria-hidden="true" class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                                <path fill-rule="evenodd"
                                    d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span class="sr-only">Close modal</span>
                        </button>
                        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-zinc-100 p-2 dark:bg-zinc-700">
                            <svg class="h-8 w-8 text-zinc-500 dark:text-zinc-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M5 7h14m-9 3v8m4-8v8M10 3h4a1 1 0 0 1 1 1v3H9V4a1 1 0 0 1 1-1ZM6 7h12v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V7Z" />
                            </svg>
                            <span class="sr-only">Danger icon</span>
                        </div>
                        <p class="mb-3.5 text-zinc-900 dark:text-white"><a href="#" class="font-medium text-primary-700 hover:underline dark:text-primary-500">@heleneeng</a>, are you sure you want to
                            delete this order from your account?</p>
                        <p class="mb-4 text-zinc-500 dark:text-zinc-300">This action cannot be undone.</p>
                        <div class="flex items-center justify-center space-x-4">
                            <button data-modal-toggle="deleteOrderModal" type="button"
                                class="rounded-lg border border-zinc-200 bg-white px-3 py-2 text-sm font-medium text-zinc-500 hover:bg-zinc-100 hover:text-zinc-900 focus:z-10 focus:outline-none focus:ring-4 focus:ring-primary-300 dark:border-zinc-500 dark:bg-zinc-700 dark:text-zinc-300 dark:hover:bg-zinc-600 dark:hover:text-white dark:focus:ring-zinc-600">
                                No, cancel
                            </button>
                            <button type="submit"
                                class="rounded-lg bg-red-700 px-3 py-2 text-center text-sm font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-4 focus:ring-red-300 dark:bg-red-600 dark:hover:bg-red-700 dark:focus:ring-red-900">
                                Yes, delete
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </section>
{% endblock %}
