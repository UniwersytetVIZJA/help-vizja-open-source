<!doctype html>
<html lang="{{ app.request.locale|default('pl') }}">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <title>{% block title %}Strona główna{% endblock %}</title>

        <link href="//cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.css" rel="stylesheet" />
        <script src="//cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"></script>
        <script src="//cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

        {% block stylesheets %}{% endblock %}
    </head>
    <body class="bg-white text-zinc-900 dark:bg-zinc-900 dark:text-zinc-100">
        <div
            id="page-loader"
            class="fixed inset-0 z-[99999] hidden items-center justify-center bg-zinc-950/40 backdrop-blur-[2px] opacity-0 transition-opacity duration-200"
            aria-hidden="true"
        >
            <div
                class="flex flex-col items-center gap-5 rounded-3xl bg-white px-10 py-8 shadow-2xl dark:bg-zinc-900"
            >
                <div
                    role="status"
                    aria-live="polite"
                    class="flex flex-col items-center gap-4"
                >
                    <svg
                        aria-hidden="true"
                        class="h-12 w-12 animate-spin text-zinc-300 fill-blue-600 dark:text-zinc-700 dark:fill-yellow-400"
                        viewBox="0 0 100 101"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                    >

                        <path
                            d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z"
                            fill="currentFill"
                        />
                    </svg>

                    <span class="text-base font-semibold tracking-wide text-zinc-800 dark:text-zinc-100">
                {% trans %}Trwa ładowanie strony…{% endtrans %}
            </span>
                </div>
            </div>
        </div>

        <div class="sr-only focus-within:not-sr-only">
            <div
                class="fixed left-1/2 top-0 z-[9999] flex -translate-x-1/2 gap-2 rounded-b-lg bg-white p-3 shadow-lg dark:bg-zinc-900">
                <a href="#main"
                    class="rounded-lg px-4 py-2 font-semibold text-blue-700 underline dark:text-yellow-400 {{ focusPrimary() }}">
                    {% trans %}Przejdź do treści{% endtrans %}
                </a>

                <a href="#footer"
                    class="rounded-lg px-4 py-2 font-semibold text-blue-700 underline dark:text-yellow-400 {{ focusPrimary() }}">
                    {% trans %}Przejdź do stopki{% endtrans %}
                </a>
            </div>
        </div>
        <header>
            <nav aria-label="{% trans %}Nawigacja górna{% endtrans %}" class="bg-white dark:bg-zinc-900">
                <div
                    class="flex flex-wrap items-center justify-between gap-2 max-w-screen-2xl min-h-[100px] mx-auto px-4 py-2.5 md:px-4">
                    <a href="{{ url('admin_dashboard') }}"
                        class="flex items-center rounded-lg min-w-0 max-w-full {{ focusPrimary() }}">
                        <div class="flex items-center justify-center gap-3 sm:gap-5">
                            <figure class="flex flex-1 justify-end">
                                <img
                                    alt="{% trans %}Przejdź do pulpitu - logo Uniwersytetu Vizja{% endtrans %}"
                                    class="block h-auto w-full max-w-[140px] sm:max-w-[200px] md:max-w-[260px] dark:hidden"
                                    src="{{ asset('images/logo/header/' ~ app.request.locale ~ '.png') }}"
                                >

                                <img
                                    alt="{% trans %}Przejdź do pulpitu - logo Uniwersytetu Vizja{% endtrans %}"
                                    class="hidden h-auto w-full max-w-[140px] sm:max-w-[200px] md:max-w-[260px] dark:block"
                                    src="{{ asset('images/logo/header/' ~ app.request.locale ~ '-transparent.png') }}"
                                >
                            </figure>

                            <figure class="flex flex-1 justify-start">
                                <img
                                    alt="{% trans %}Logo Biura do spraw osób z niepełnosprawnościami{% endtrans %}"
                                    class="block h-auto w-full max-w-[180px] sm:max-w-[260px] md:max-w-[320px] dark:hidden"
                                    src="{{ asset('images/logo/bon/' ~ app.request.locale ~ '.png') }}"
                                >

                                <img
                                    alt="{% trans %}Logo Biura do spraw osób z niepełnosprawnościami{% endtrans %}"
                                    class="hidden h-auto w-full max-w-[180px] sm:max-w-[260px] md:max-w-[320px] dark:block"
                                    src="{{ asset('images/logo/bon/' ~ app.request.locale ~ '-transparent.png') }}"
                                >
                            </figure>
                        </div>
                    </a>

                    <div class="flex flex-wrap items-center justify-end gap-2 max-w-full min-w-0">
                        {% include 'admin/_components/change-theme.html.twig' %}
                        {% include 'student/_components/change-language.html.twig' %}

                        <div class="hidden lg:flex items-center gap-3 rounded-lg px-3 py-2">
                            <div
                                class="w-10 h-10 rounded-full bg-blue-600 text-white dark:text-black flex items-center justify-center text-sm font-semibold overflow-hidden shrink-0 dark:bg-yellow-400">
        <span class="avatar-initials hidden">
            {{ app.user.initials }}
        </span>

                                <img
                                    src="{{ path('admin_user_ms_avatar') }}"
                                    alt="Zdjęcie profilowe"
                                    class="w-10 h-10 rounded-full object-cover"
                                    onerror="
                this.style.display='none';
                this.parentElement.querySelector('.avatar-initials').classList.remove('hidden');
            "
                                >
                            </div>

                            <div class="min-w-0">
                                <p class="truncate text-sm font-medium text-zinc-900 dark:text-white">
                                    {{ app.user.firstName }} {{ app.user.lastName }}
                                </p>

                                <p class="truncate text-xs text-zinc-500 dark:text-zinc-400">
                                    {{ app.user.email }}
                                </p>
                            </div>
                        </div>

                        <a href="{{ url('admin_logout_full') }}"
                            class="font-medium items-center p-2 rounded-lg text-sm dark:hover:bg-zinc-800 hover:bg-zinc-50 lg:block {{ focusPrimary() }}">
                            {% trans %}Wyloguj{% endtrans %}
                        </a>

                        <button type="button"
                            class="font-medium inline-flex items-center p-2 rounded-lg text-sm dark:hover:bg-zinc-800 hover:bg-zinc-50 lg:hidden {{ focusPrimary() }}"
                            data-collapse-toggle="toggle-navigation"
                            id="toggle-navigation-button"
                        >
                            <span class="sr-only">{% trans %}Otwórz nawigację{% endtrans %}</span>
                            <svg class="w-6 h-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-width="2"
                                    d="M5 7h14M5 12h14M5 17h14" />
                            </svg>
                        </button>
                    </div>
                </div>
            </nav>

            <nav id="toggle-navigation" aria-label="{% trans %}Nawigacja główna{% endtrans %}"
                class="bg-zinc-50 hidden dark:bg-zinc-800 lg:block {{ borderNavigation() }}">
                <div class="grid mx-auto max-w-screen-2xl px-4">
                    <div class="flex items-center min-w-0">
                        <ul class="flex flex-col font-medium mt-0 text-base w-full min-w-0 lg:flex-row">
                            <li class="min-w-0">
                                <a id="pulpit" href="{{ url('admin_dashboard') }}"
                                    class="block w-full px-3 py-4 rounded-lg text-center wrap-break-word dark:hover:text-yellow-400 hover:text-blue-600 {{ focusPrimary() }}">
                                    {% trans %}Pulpit{% endtrans %}
                                </a>
                            </li>

                            <li class="min-w-0">
                                <a id="zapisy"
                                    href="{{ path('admin_registration') }}"
                                    class="block w-full px-3 py-4 rounded-lg text-center wrap-break-word dark:hover:text-yellow-400 hover:text-blue-600 {{ focusPrimary() }}">
                                    {% trans %}Zapisy na konsultacje{% endtrans %}
                                </a>
                            </li>
                            <li class="min-w-0">
                                <a id="wizyty" href="{{ path('admin_office_registration_terms') }}"
                                    class="block w-full px-3 py-4 rounded-lg text-center wrap-break-word dark:hover:text-yellow-400 hover:text-blue-600 {{ focusPrimary() }}">
                                    {% trans %}Wizyty w biurze{% endtrans %}
                                </a>
                            </li>
                            <li class="min-w-0">
                                <a id="wnioski" href="{{ path('admin_applications') }}"
                                    class="block w-full px-3 py-4 rounded-lg text-center wrap-break-word dark:hover:text-yellow-400 hover:text-blue-600 {{ focusPrimary() }}">
                                    {% trans %}Wnioski{% endtrans %}
                                </a>
                            </li>
                            {% if is_granted('ROLE_EMPLOYEE') %}
                                <li class="min-w-0">
                                    <a id="sprzet" href="{{ path('admin_inventory') }}"
                                        class="block w-full px-3 py-4 rounded-lg text-center wrap-break-word dark:hover:text-yellow-400 hover:text-blue-600 {{ focusPrimary() }}">
                                        {% trans %}Sprzęt{% endtrans %}
                                    </a>
                                </li>
                            {% endif %}
                            <li class="min-w-0">
                                <a id="mapa_strony" href="{{ path('admin_website_map') }}"
                                    class="block w-full px-3 py-4 rounded-lg text-center wrap-break-word dark:hover:text-yellow-400 hover:text-blue-600 {{ focusPrimary() }}">
                                    {% trans %}Mapa strony{% endtrans %}
                                </a>
                            </li>
                            <li class="min-w-0">
                                <a id="ustawienia" href="{{ path('admin_settings') }}"
                                    class="block w-full px-3 py-4 rounded-lg text-center wrap-break-word dark:hover:text-yellow-400 hover:text-blue-600 {{ focusPrimary() }}">
                                    {% trans %}Ustawienia{% endtrans %}
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
            <div class="bg-white flex items-center justify-center px-4">
                <img
                    alt="{% trans %}Logo Funduszy Europejskich{% endtrans %}"
                    class="block w-full max-w-[800px] h-auto py-5"
                    src="{{ asset('images/logo/unijne-logotypy/' ~ app.request.locale ~ '.png') }}"
                >
            </div>
        </header>

        <main id="main" role="main" aria-labelledby="page-title">
            <div class="mx-auto max-w-screen-2xl pb-8 pt-4 px-4 lg:py-10 min-w-0">
                <div class='py-5 min-w-0' aria-live="polite" aria-atomic="true">
                    {% include 'admin/_components/_flashes.html.twig' %}
                </div>

                {% block body %}{% endblock %}
            </div>
        </main>

        <a
            href="https://tlumacz.migam.org/Vizja"
            rel="noopener noreferrer"
            class="block bg-white p-5 shadow-lg transition hover:bg-zinc-100 dark:bg-zinc-800 dark:hover:bg-zinc-700 {{ focusPrimaryWithPadding() }}"
        >
            <div class="flex items-center justify-center gap-4 text-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="text-blue-600 dark:text-yellow-400" width="62.957" height="54.519" viewBox="0 0 62.957 54.519">
