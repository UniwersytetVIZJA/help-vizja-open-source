        </footer>

        <script>
            (function () {
                const loader = document.getElementById('page-loader');
                if (!loader) return;

                let loaderTimer = null;
                let watchdogTimer = null;
                let visible = false;

                const DELAY = 800;
                const WATCHDOG = 4000;

                function showLoader() {
                    visible = true;

                    loader.classList.remove('hidden', 'opacity-0');
                    loader.classList.add('flex');

                    requestAnimationFrame(() => {
                        loader.classList.add('opacity-100');
                    });

                    document.documentElement.classList.add('overflow-hidden');
                    document.body.classList.add('overflow-hidden');
                }

                function hideLoader() {
                    clearTimeout(loaderTimer);
                    clearTimeout(watchdogTimer);

                    visible = false;

                    loader.classList.remove('opacity-100');
                    loader.classList.add('opacity-0');

                    document.documentElement.classList.remove('overflow-hidden');
                    document.body.classList.remove('overflow-hidden');

                    setTimeout(() => {
                        if (!visible) {
                            loader.classList.remove('flex');
                            loader.classList.add('hidden');
                        }
                    }, 200);
                }

                function scheduleLoader() {
                    clearTimeout(loaderTimer);
                    clearTimeout(watchdogTimer);

                    loaderTimer = setTimeout(() => {
                        showLoader();

                        // zabezpieczenie dla pobierania plików / anulowanej nawigacji
                        watchdogTimer = setTimeout(hideLoader, WATCHDOG);
                    }, DELAY);
                }

                function shouldSkipLink(link, event) {
                    const href = link.getAttribute('href');

                    if (!href) return true;
                    if (event.defaultPrevented) return true;
                    if (event.button !== 0) return true;
                    if (event.ctrlKey || event.metaKey || event.shiftKey || event.altKey) return true;
                    if (link.target && link.target !== '_self') return true;
                    if (link.hasAttribute('download')) return true;
                    if (link.dataset.noLoader !== undefined) return true;

                    if (
                        href.startsWith('#') ||
                        href.startsWith('mailto:') ||
                        href.startsWith('tel:') ||
                        href.startsWith('javascript:')
                    ) {
                        return true;
                    }

                    const url = new URL(href, window.location.href);

                    if (url.origin !== window.location.origin) return true;

                    const downloadExtensions = [
                        '.pdf', '.zip', '.rar', '.7z',
                        '.doc', '.docx', '.xls', '.xlsx',
                        '.csv', '.xml',
                        '.jpg', '.jpeg', '.png', '.webp'
                    ];

                    return downloadExtensions.some(ext =>
                        url.pathname.toLowerCase().endsWith(ext)
                    );
                }

                document.addEventListener('click', function (event) {
                    const link = event.target.closest('a[href]');
                    if (!link) return;

                    if (shouldSkipLink(link, event)) {
                        hideLoader();
                        return;
                    }

                    scheduleLoader();
                });

                document.addEventListener('submit', function (event) {
                    if (!(event.target instanceof HTMLFormElement)) return;
                    if (event.target.dataset.noLoader !== undefined) return;

                    scheduleLoader();
                });

                window.addEventListener('load', hideLoader);
                window.addEventListener('pageshow', hideLoader);
                window.addEventListener('pagehide', hideLoader);
                window.addEventListener('focus', hideLoader);
                window.addEventListener('visibilitychange', function () {
                    if (!document.hidden) hideLoader();
                });
            })();
        </script>

        {% block javascripts %}{% endblock %}
    </body>
</html>

