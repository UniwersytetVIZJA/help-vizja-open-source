                            transform="translate(1810.663 45.715)" fill="currentColor" />
                    </g>
                </svg>

                <div>
                    <h2 class="text-lg font-semibold text-zinc-900 dark:text-white">
                        {% trans %}Połącz się z tłumaczem języka migowego{% endtrans %}
                    </h2>

                    <p class="mt-1 text-base">
                        {% trans %}Uniwersytet VIZJA - tlumacz.migam.org{% endtrans %}
                    </p>
                </div>
            </div>
        </a>

        <footer class="bg-zinc-900 py-10 text-zinc-100" id="footer">
            <div class="mx-auto max-w-screen-2xl px-4 text-center min-w-0">
                <ul class="flex flex-col md:flex-row justify-center items-center min-w-0">
                    <li class="min-w-0">
                        <a href="{{ app.request.locale == 'pl'
                        ? 'https://vizja.pl/kontakt/#biuro-rekrutacji'
                        : 'https://vizja.pl/en/contact/#biuro-rekrutacji' }}"
                            class="block px-4 py-2 rounded-lg underline hover:text-yellow-400 break-words {{ focusPrimary() }}">
                            {% trans %}Biuro Rekrutacji{% endtrans %}
                        </a>
                    </li>
                    <li class="min-w-0">

                        <a href="{{ app.request.locale == 'pl'
                        ? 'https://bon.vizja.pl/kontakt/'
                        : 'https://vizja.pl/en/contact' }}"
                            class="block px-4 py-2 rounded-lg underline hover:text-yellow-400 wrap-break-word {{ focusPrimary() }}">
                            {% trans %}Kontakt{% endtrans %}
                        </a>
                    </li>
                    <li class="min-w-0">

                        <a href="{{ app.request.locale == 'pl'
                        ? 'https://vizja.pl/kontakt/#social-media'
                        : 'https://vizja.pl/en/contact/#social-media' }}"
                            class="block px-4 py-2 rounded-lg underline hover:text-yellow-400 wrap-break-word {{ focusPrimary() }}">
                            {% trans %}Social media{% endtrans %}
                        </a>
                    </li>
                    <li class="min-w-0">
                        <a href="{{ app.request.locale == 'pl'
                        ? 'https://vizja.pl/polityka-prywatnosci'
                        : 'https://vizja.pl/en/polityka-prywatnosci/' }}"
                            class="block px-4 py-2 rounded-lg underline hover:text-yellow-400 wrap-break-word {{ focusPrimary() }}">
                            {% trans %}Polityka prywatności{% endtrans %}
                        </a>
                    </li>

                    <li class="min-w-0">
                        <a href="{{ app.request.locale == 'pl'
                        ? 'https://vizja.pl/accessibility-statement/'
                        : 'https://vizja.pl/en/accessibility-statement/' }}"
                            class="block px-4 py-2 rounded-lg underline hover:text-yellow-400 wrap-break-word {{ focusPrimary() }}">
                            {% trans %}Deklaracja dostępności{% endtrans %}
                        </a>
                    </li>
                </ul>

                <div class="my-10"></div>

                <div class="flex flex-col justify-center items-center min-w-0">
                    {% if app.request.locale == 'pl' %}
                        <img alt="{% trans %}Logo Uniwersytetu Vizja{% endtrans %}"
                            class="block w-full max-w-[260px] h-auto mb-10"
                            src="{{ asset('images/logo/uv/logo_pl_PL_poziom_kontra.png') }}">
                    {% elseif app.request.locale == 'en' %}
                        <img alt="{% trans %}Logo Uniwersytetu Vizja{% endtrans %}"
                            class="block w-full max-w-[260px] h-auto mb-10"
                            src="{{ asset('images/logo/uv/logo_en_US_poziom_kontra.png') }}">
                    {% endif %}

                </div>

                <div class="flex flex-col justify-center items-center gap-y-2 text-sm min-w-0">
                    <div class="wrap-break-word">
                        {% trans %}ul. Okopowa 59{% endtrans %}
                    </div>
                    <div class="wrap-break-word">
                        01-043, {% trans %}Warszawa{% endtrans %}
                    </div>
                    <div class="wrap-break-word">
                        {% trans %}piętro{% endtrans %} II, {% trans %}pokój{% endtrans %} 233
                    </div>
                    <div class="mt-10 mb-5 px-4 w-full min-w-0">
                        <div class="max-w-screen-2xl mx-auto text-left min-w-0">
                            <div class="max-w-none wrap-break-word min-w-0">
                                {% trans %}Program do zarządzania usługami Biura ds. Osób z Niepełnosprawnościami (BON) został opracowany przez Uniwersytet VIZJA w ramach realizacji projektu{% endtrans %}
                                <a class="underline wrap-break-word" rel="noopener noreferrer"
                                    href="https://vizja.pl/projekty-europejskie/vizja-home-uczelnia-dla-wszystkich/">
                                    {% trans %}Vizja Home – Uczelnia dla wszystkich{% endtrans %}
                                </a>
                                {% trans %}w ramach programu Fundusze Europejskie dla Rozwoju Społecznego 2021-2027 współfinansowanego ze środków Europejskiego Funduszu Społecznego Plus i objęty jest w całości licencją{% endtrans %}
                                <a class="underline wrap-break-word" rel="noopener noreferrer"
                                    href="https://creativecommons.org/licenses/by/4.0/legalcode.pl">
                                    {% trans %}Creative Commons Uznanie autorstwa CC BY 4.0{% endtrans %}
                                </a>.
                                <p class="mt-2">
                                    <a class="underline wrap-break-word" rel="noopener noreferrer"
                                        href="{{ url('admin_license_index') }}">
                                        {% trans %}Więcej o Help VIZJA i licencji{% endtrans %}
                                    </a>
                                </p>

                                <div class="mt-7">
                                    <div class="flex flex-wrap items-center gap-2" role="img"
                                        aria-label="{% trans %}Logo licencji Creative Commons – Uznanie autorstwa{% endtrans %}">
                                        <svg class="fill-white w-8 h-8 shrink-0" xmlns="http://www.w3.org/2000/svg"
                                            viewBox="0 0 640 640">
