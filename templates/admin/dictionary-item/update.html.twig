{% extends 'admin/_layouts/after-login.html.twig' %}
{% form_theme form 'student/_layouts/form-tailwind.html.twig' %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}
{% block title %}{% trans %}Edycja wartości{% endtrans %}{% endblock %}
{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}

{% block body %}

    {{ website_path([
        { label: 'Ustawienia'|trans, route: 'admin_settings' },
        { label: 'Słownik'|trans, route: 'admin_dictionaries' },
        { label: 'Wartości'|trans, route: 'admin_dictionary_items', route_params: { dictionaryId: dictionary.id } },
        { label: 'Edytuj wartość'|trans },
    ]) }}

    <div class="overflow-hidden relative sm:rounded-lg">
        <div class="flex flex-col justify-between p-4 space-y-3 md:flex-row md:space-x-4 md:space-y-0">
            <h1 class="text-2xl font-bold mb-4">{% trans %}Edytuj wartość{% endtrans %}</h1>
        </div>
        <div class="justify-between p-4 space-y-3 md:max-w-5xl md:space-x-4 md:space-y-0">
            {% include 'admin/dictionary-item/_partials/form.html.twig' %}
        </div>
    </div>
{% endblock %}

