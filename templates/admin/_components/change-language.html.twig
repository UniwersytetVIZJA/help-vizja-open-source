{% set qs_pl = app.request.query.all|merge({'_locale':'pl'}) %}
{% set qs_en = app.request.query.all|merge({'_locale':'en'}) %}

<button type="button"
    class="font-medium inline-flex items-center justify-end me-2 p-2 rounded-lg text-sm dark:hover:bg-zinc-700 focus:outline-none focus:ring-3 focus:ring-blue-300 hover:bg-zinc-100"
    data-dropdown-toggle="change-language-dropdown"
    id="change-language-button"
>
    <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
        <path fill-rule="evenodd"
            d="M8.64 4.737A7.97 7.97 0 0 1 12 4a7.997 7.997 0 0 1 6.933 4.006h-.738c-.65 0-1.177.25-1.177.9 0 .33 0 2.04-2.026 2.008-1.972 0-1.972-1.732-1.972-2.008 0-1.429-.787-1.65-1.752-1.923-.374-.105-.774-.218-1.166-.411-1.004-.497-1.347-1.183-1.461-1.835ZM6 4a10.06 10.06 0 0 0-2.812 3.27A9.956 9.956 0 0 0 2 12c0 5.289 4.106 9.619 9.304 9.976l.054.004a10.12 10.12 0 0 0 1.155.007h.002a10.024 10.024 0 0 0 1.5-.19 9.925 9.925 0 0 0 2.259-.754 10.041 10.041 0 0 0 4.987-5.263A9.917 9.917 0 0 0 22 12a10.025 10.025 0 0 0-.315-2.5A10.001 10.001 0 0 0 12 2a9.964 9.964 0 0 0-6 2Zm13.372 11.113a2.575 2.575 0 0 0-.75-.112h-.217A3.405 3.405 0 0 0 15 18.405v1.014a8.027 8.027 0 0 0 4.372-4.307ZM12.114 20H12A8 8 0 0 1 5.1 7.95c.95.541 1.421 1.537 1.835 2.415.209.441.403.853.637 1.162.54.712 1.063 1.019 1.591 1.328.52.305 1.047.613 1.6 1.316 1.44 1.825 1.419 4.366 1.35 5.828Z"
            clip-rule="evenodd"></path>
    </svg>
    <svg class="h-2.5 ms-3 w-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"></path>
    </svg>
</button>

<div class="bg-white divide-zinc-100 divide-y hidden rounded-lg shadow-sm z-10 dark:bg-zinc-700 dark:divide-zinc-600 w-24" id="change-language-dropdown">
    <ul aria-labelledby="change-language-button" class="p-2 text-sm text-center">
        <li>
            <a href="{{ app.request.pathInfo ~ '?' ~ (qs_pl|url_encode) }}"
                class="block px-4 py-2 rounded-lg dark:hover:bg-zinc-600 focus:outline-none focus:ring-3 focus:ring-blue-300 hover:bg-zinc-100">
                Polski
            </a>
        </li>
        <li>
            <a href="{{ app.request.pathInfo ~ '?' ~ (qs_en|url_encode) }}"
                class="block px-4 py-2 rounded-lg dark:hover:bg-zinc-600 focus:outline-none focus:ring-3 focus:ring-blue-300 hover:bg-zinc-100">
                English
            </a>
        </li>
    </ul>
</div>
