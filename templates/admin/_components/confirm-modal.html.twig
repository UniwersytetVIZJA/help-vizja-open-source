{# WYMAGANE ZMIENNE:
    modalId       - unikalne ID modala
    formId        - ID formularza, który ma być submitowany
    title         - tytuł modala
    message       - główna treść
    warningText   - tekst ostrzeżenia (opcjonalnie)
    confirmLabel  - tekst na przycisku potwierdzenia
    cancelLabel   - tekst na przycisku anulowania
#}

<div
    id="{{ modalId }}"
    tabindex="-1"
    role="dialog"
    aria-modal="true"
    aria-labelledby="{{ modalId }}-title"
    aria-describedby="{{ modalId }}-description{% if warningText is defined and warningText %} {{ modalId }}-warning{% endif %}"
    aria-hidden="true"
    class="hidden fixed inset-0 z-50 h-modal w-full items-center justify-center overflow-y-auto overflow-x-hidden md:h-full md:inset-0"
>
    <div class="relative h-full w-full max-w-md p-4 md:h-auto">
        <div class="relative rounded-lg bg-white p-4 text-center shadow dark:bg-zinc-800 sm:p-5">
            <button
                type="button"
                data-modal-hide="{{ modalId }}"
                aria-label="{% trans %}Zamknij okno{% endtrans %}"
                class="absolute right-2.5 top-2.5 inline-flex items-center justify-center rounded-lg bg-transparent p-2 text-zinc-900 hover:bg-zinc-200 hover:text-zinc-950 dark:text-white dark:hover:bg-zinc-600 dark:hover:text-white {{ focusPrimaryWithPadding() }}"
            >
                <svg aria-hidden="true" focusable="false" class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd"
                        d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                        clip-rule="evenodd" />
                </svg>
            </button>

            <h2
                id="{{ modalId }}-title"
                tabindex="-1"
                class="mb-2 text-lg font-semibold text-zinc-900 dark:text-white"
            >
                {{ title }}
            </h2>

            {% if message is defined and message %}
                <p id="{{ modalId }}-description" class="mb-4 text-base text-zinc-900 dark:text-zinc-100">
                    {{ message }}
                </p>
            {% else %}
                <p id="{{ modalId }}-description" class="sr-only">
                    {% trans %}Okno potwierdzenia akcji{% endtrans %}
                </p>
            {% endif %}

            {% if warningText is defined and warningText %}
                <div
                    id="{{ modalId }}-warning"
                    class="mb-4 rounded-lg bg-orange-100 p-4 text-left text-sm text-orange-700 dark:bg-zinc-700 dark:text-orange-300 sm:mb-5"
                >
                    <div class="mb-1 flex items-center">
                        <svg class="mr-1 h-4 w-4 flex-shrink-0" aria-hidden="true" focusable="false" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                                clip-rule="evenodd" />
                        </svg>
                        <span class="font-semibold leading-none">{% trans %}Uwaga{% endtrans %}</span>
                    </div>

                    <p>{{ warningText }}</p>
                </div>
            {% endif %}

            <div class="flex items-center justify-center space-x-4">
                <button
                    type="button"
                    data-modal-hide="{{ modalId }}"
                    class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}"
                >
                    {{ cancelLabel|default('') }}
                </button>

                <button
                    type="submit"
                    form="{{ formId }}"
                    class="{{ buttonDelete() }} {{ focusPrimaryWithPadding() }}"
                >
                    {{ confirmLabel|default('') }}
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        let previouslyFocusedElement = null;

        const getFocusableElements = (modal) => {
            return [...modal.querySelectorAll(
                'a[href], button:not([disabled]), textarea:not([disabled]), input:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])'
            )].filter((el) => !el.hasAttribute('aria-hidden'));
        };

        const focusTitle = (modal) => {
            const title = modal.querySelector('[id$="-title"]');

            if (title) {
                title.focus({ preventScroll: true });
            }
        };

        const trapFocus = (event) => {
            const modal = document.querySelector('[role="dialog"]:not(.hidden)');

            if (!modal || event.key !== 'Tab') {
                return;
            }

            const focusable = getFocusableElements(modal);

            if (!focusable.length) {
                event.preventDefault();
                focusTitle(modal);
                return;
            }

            const first = focusable[0];
            const last = focusable[focusable.length - 1];

            if (event.shiftKey && document.activeElement === first) {
                event.preventDefault();
                last.focus();
            }

            if (!event.shiftKey && document.activeElement === last) {
                event.preventDefault();
                first.focus();
            }
        };

        const observer = new MutationObserver(() => {
            document.querySelectorAll('[role="dialog"]').forEach((modal) => {
                const isOpen = !modal.classList.contains('hidden');

                if (isOpen && modal.dataset.focusHandled !== '1') {
                    previouslyFocusedElement = document.activeElement;
                    modal.dataset.focusHandled = '1';

                    window.setTimeout(() => {
                        focusTitle(modal);
                    }, 50);
                }

                if (!isOpen && modal.dataset.focusHandled === '1') {
                    modal.dataset.focusHandled = '0';

                    if (previouslyFocusedElement) {
                        previouslyFocusedElement.focus({ preventScroll: true });
                        previouslyFocusedElement = null;
                    }
                }
            });
        });

        document.querySelectorAll('[role="dialog"]').forEach((modal) => {
            observer.observe(modal, {
                attributes: true,
                attributeFilter: ['class']
            });
        });

        document.addEventListener('keydown', trapFocus);
    });
</script>
