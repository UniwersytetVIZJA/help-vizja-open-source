{% extends 'admin/_layouts/after-login.html.twig' %}

{% block title %}{% trans %}Wnioski{% endtrans %} | Admin Help VIZJA{% endblock %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}

{% block body %}
    <section class="p-4 rounded-lg">
        <h1 class="text-xl font-semibold text-zinc-900 dark:text-white sm:text-2xl md:text-3xl">
            {% trans %}Lista wszystkich wniosków{% endtrans %}
        </h1>

        <div class="overflow-x-auto my-10">

            {# --- FILTRY --- #}
            <form method="get"
                action="{{ path('admin_applications_search') }}"
                class="mb-4 grid grid-cols-1 md:grid-cols-5 gap-3 p-4 rounded-xl border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900">

                {# Typ wniosku #}
                <div>
                    <label for="f-type" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">
                        {% trans %}Typ wniosku{% endtrans %}
                    </label>
                    <select id="f-type" name="type"
                        class="border-2 w-full rounded-lg border-zinc-5000 dark:border-zinc-300 bg-white dark:bg-zinc-800 px-3 py-2 {{ focusPrimary() }}">
                        <option value="">— {% trans %}wszystkie{% endtrans %} —</option>
                        <option value="educational_process" {{ filters.type == 'educational_process' ? 'selected' }}>
                            {% trans %}Adaptacja procesu kształcenia{% endtrans %}
                        </option>
                        <option value="teaching_assistant" {{ filters.type == 'teaching_assistant' ? 'selected' }}>
                            {% trans %}Organizacja wsparcia asystenta dydaktycznego{% endtrans %}
                        </option>
                        <option value="language_interpreter" {{ filters.type == 'language_interpreter' ? 'selected' }}>
                            {% trans %}Przyznanie tłumacza języka migowego{% endtrans %}
                        </option>
                        <option value="specialised_equipment" {{ filters.type == 'specialised_equipment' ? 'selected' }}>
                            {% trans %}Wypożyczenie sprzętu specjalistycznego{% endtrans %}
                        </option>
                    </select>
                </div>

                {# Student (imię/nazwisko) #}
                <div>
                    <label for="f-student" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">
                        {% trans %}Student{% endtrans %}
                    </label>
                    <input id="f-student" name="student" type="text"
                        value="{{ filters.student ?? '' }}"
                        placeholder="np. Jan Kowalski"
                        class="border-2 w-full rounded-lg border-zinc-500 dark:border-zinc-300 bg-white dark:bg-zinc-800 px-3 py-2 {{ focusPrimary() }}" />
                </div>

                {# Status #}
                <div>
                    <label for="f-status" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">
                        {% trans %}Status{% endtrans %}
                    </label>
                    <select id="f-status" name="status"
                        class="border-2 w-full rounded-lg border-zinc-500 dark:border-zinc-300 bg-white dark:bg-zinc-800 px-3 py-2 {{ focusPrimary() }}">
                        <option value="">— {% trans %}dowolny{% endtrans %} —</option>
                        <option value="Nowy" {{ filters.status == 'Nowy' ? 'selected' }}>
                            {% trans %}Nowy{% endtrans %}
                        </option>
                        <option value="W trakcie" {{ filters.status == 'W trakcie' ? 'selected' }}>
                            {% trans %}W trakcie{% endtrans %}
                        </option>
                        <option value="Zaakceptowany" {{ filters.status == 'Zaakceptowany' ? 'selected' }}>
                            {% trans %}Zaakceptowany{% endtrans %}
                        </option>
                        <option value="Odrzucony" {{ filters.status == 'Odrzucony' ? 'selected' }}>
                            {% trans %}Odrzucony{% endtrans %}
                        </option>
                    </select>
                </div>

                {# Data od #}
                <div>
                    <label for="f-from" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">
                        {% trans %}Data - szukaj od{% endtrans %}
                    </label>
                    <input id="f-from" name="from" type="date"
                        min="1900-01-01"
                        max="2099-12-31"
                        value="{{ filters.from ? filters.from|date('Y-m-d') : '' }}"
                        class="border-2 w-full rounded-lg border-zinc-5000 dark:border-zinc-300 bg-white dark:bg-zinc-800 px-3 py-2 {{ focusPrimary() }}" />
                </div>

                {# Data do #}
                <div>
                    <label for="f-to" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">
                        {% trans %}Data - szukaj do{% endtrans %}
                    </label>
                    <input id="f-to" name="to" type="date"
                        min="1900-01-01"
                        max="2099-12-31"
                        value="{{ filters.to ? filters.to|date('Y-m-d') : '' }}"
                        class="border-2 w-full rounded-lg border-zinc-5000 dark:border-zinc-300 bg-white dark:bg-zinc-800 px-3 py-2 {{ focusPrimary() }}" />
                </div>

                <div class="md:col-span-5 flex items-center justify-end gap-2 pt-1">
                    <button class="cursor-pointer {{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}" type="submit">
                        {% trans %}Szukaj{% endtrans %}
                    </button>
                    <a class="{{ buttonSecondary() }} {{ focusPrimaryWithPadding() }}" href="{{ url('admin_applications_search') }}">
                        {% trans %}Wyczyść{% endtrans %}
                    </a>
                </div>
            </form>

            <table class="w-full text-left text-sm text-zinc-900 dark:text-white border">
                <caption class="sr-only">
                    {% trans %}Lista wniosków{% endtrans %}
                </caption>

                <thead class="bg-zinc-200 text-sm font-semibold text-zinc-900 dark:bg-zinc-700 dark:text-white">
                    <tr class="border-b ">
                        <th scope="col" class="p-4 font-semibold">{% trans %}Lp.{% endtrans %}</th>
                        <th scope="col" class="px-4 py-3 font-semibold">{% trans %}Data utworzenia{% endtrans %}</th>
                        <th scope="col" class="px-4 py-3 font-semibold">{% trans %}Numer wniosku{% endtrans %}</th>
                        <th scope="col" class="px-4 py-3 font-semibold">{% trans %}Numer albumu{% endtrans %}</th>
                        <th scope="col" class="px-4 py-3 font-semibold">{% trans %}Imię i nazwisko{% endtrans %}</th>
                        <th scope="col" class="px-4 py-3 font-semibold">{% trans %}Rodzaj wniosku{% endtrans %}</th>
                        <th scope="col" class="px-4 py-3 font-semibold">{% trans %}Status{% endtrans %}</th>
                        <th scope="col" class="px-4 py-3 font-semibold whitespace-nowrap">{% trans %}Akcje{% endtrans %}</th>
                    </tr>
                </thead>

                <tbody>
                    {% for application in applications %}
                        <tr
                            class="cursor-pointer border-b hover:bg-zinc-100 dark:hover:bg-zinc-700"
                            onclick="window.location='{{ path('admin_applications_applicationDetails', { applicationId: application.id }) }}'"
                        >
                            <td class="w-4 px-4 py-3 text-zinc-900 dark:text-white">
                                <div class="flex items-center">
                        <span class="px-4 py-2 whitespace-nowrap text-zinc-900 dark:text-white">
                            {{ loop.index }}.
                        </span>
                                </div>
                            </td>

                            <td class="px-4 py-2 whitespace-nowrap text-zinc-900 dark:text-white">
                                {{ application.createdAt | date('d.m.Y H:i') }}
                            </td>

                            <td class="px-4 py-2 whitespace-nowrap text-zinc-900 dark:text-white">
                                {{ application.applicationNumber }}
                            </td>

                            <td class="px-4 py-2 whitespace-nowrap text-zinc-900 dark:text-white">
                                {{ application.albumNumber }}
                            </td>

                            <td class="px-4 py-2 whitespace-nowrap text-zinc-900 dark:text-white">
                                {{ application.student.firstName }} {{ application.student.lastName }}
                            </td>

                            <td class="px-4 py-2">
                                <div class="inline-flex items-center bg-primary-100 text-primary-800 text-xs font-medium px-2 py-0.5 rounded dark:bg-primary-900 dark:text-primary-300">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 mr-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
                                        <path fill-rule="evenodd" clip-rule="evenodd"
                                            d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" />
                                    </svg>

                                    {% if app.request.locale == 'pl' %}
                                        {{ application.type.value }}
                                    {% else %}
                                        {{ application.type.valueEnglish }}
                                    {% endif %}
                                </div>
                            </td>

                            {% set statusColors = {
                                'Nowy': 'bg-zinc-300',
                                'W trakcie': 'bg-yellow-500',
                                'Do poprawy': 'bg-red-500',
                                'Odrzucony': 'bg-red-500',
                                'Zaakceptowany': 'bg-green-500',
                            } %}

                            <td class="px-4 py-2 whitespace-nowrap text-zinc-900 dark:text-white">
                                <div class="flex items-center">
                                    <div class="w-3 h-3 mr-2 border rounded-full {{ statusColors[application.status]|default('bg-zinc-500') }}"></div>
                                    {{ application.status }}
                                </div>
                            </td>

                            <td class="px-4 py-2 whitespace-nowrap">
                                <a
                                    class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}"
                                    href="{{ url('admin_applications_applicationDetails', { applicationId: application.id }) }}"
                                >
                                    {% trans %}Podgląd{% endtrans %}
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    {% include '_paginator/paginator.html.twig' with { pagination: pagination } %}
{% endblock %}
