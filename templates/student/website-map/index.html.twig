{% extends 'student/_layouts/after-login.html.twig' %}
{% block title %}{% trans %}Mapa strony{% endtrans %} | Help VIZJA{% endblock %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}


{% block body %}
    <section class="space-y-8">
        <header class="space-y-3">
            <h1 id="page-title" class="text-2xl font-bold md:text-3xl">
                {% trans %}Mapa strony{% endtrans %}
            </h1>

            <p class="max-w-3xl text-zinc-700 dark:text-zinc-300">
                {% trans %}Poniżej znajduje się lista najważniejszych sekcji i podstron serwisu Help VIZJA.{% endtrans %}
            </p>
        </header>

        <nav aria-labelledby="site-map-heading" class="space-y-8">

            <section aria-labelledby="main-pages-heading" class="space-y-4">
                <h2 id="main-pages-heading" class="text-xl font-semibold">
                    {% trans %}Główne sekcje{% endtrans %}
                </h2>

                <ul class="list-disc space-y-3 ps-6">
                    <li>
                        <a href="{{ path('student_dashboard') }}" class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                            {% trans %}Pulpit{% endtrans %}
                        </a>
                    </li>

                    <li>
                        <a href="{{ path('student_announcements') }}" class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                            {% trans %}Ogłoszenia{% endtrans %}
                        </a>
                    </li>

                    <li>
                        <a href="{{ path('student_registration_menu') }}" class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                            {% trans %}Konsultacje{% endtrans %}
                        </a>

                        <ul class="mt-2 ml-4 list-disc space-y-1">
                            <li>
                                <a href="{{ path('student_select_registration') }}" class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                                    {% trans %}Zapisz się na konsultację{% endtrans %}
                                </a>
                            </li>

                            <li>
                                <a href="{{ path('student_my_registrations') }}" class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                                    {% trans %}Moje zapisy na konsultacje{% endtrans %}
                                </a>
                            </li>
                        </ul>
                    </li>

                    {% if is_granted("ROLE_STUDENT") %}
                    <li>
                        <a href="{{ path('student_office_registration_menu') }}"
                           class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                            {% trans %}Wizyty w BON{% endtrans %}
                        </a>

                        <ul class="mt-2 ml-4 list-disc space-y-1">
                            <li>
                                <a href="{{ path('student_office_registration_step_1') }}" class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                                    {% trans %}Zapisz się na wizytę w BON{% endtrans %}
                                </a>
                            </li>

                            <li>
                                <a href="{{ path('student_registration_center_my_registrations') }}" class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                                    {% trans %}Moje wizyty w BON{% endtrans %}
                                </a>
                            </li>
                        </ul>
                    </li>
                    {% endif %}
                </ul>
            </section>

            {% if is_granted("ROLE_STUDENT") %}
            <section aria-labelledby="applications-heading" class="space-y-4">
                <h2 id="applications-heading" class="text-xl font-semibold">
                    {% trans %}Wnioski{% endtrans %}
                </h2>

                <ul class="list-disc space-y-3 ps-6">
                    <li>
                        <a href="{{ path('student_application_index') }}" class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                            {% trans %}Lista wniosków{% endtrans %}
                        </a>
                    </li>

                    <li>
                        <a href="{{ path('student_choose_application_type') }}" class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                            {% trans %}Złóż nowy wniosek{% endtrans %}
                        </a>
                    </li>
                </ul>
            </section>
            {% endif %}

            <section aria-labelledby="profile-heading" class="space-y-4">
                <h2 id="profile-heading" class="text-xl font-semibold">
                    {% trans %}Profil użytkownika{% endtrans %}
                </h2>

                <ul class="list-disc space-y-3 ps-6">
                    <li>
                        <a href="{{ path('student_profile_index') }}" class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                            {% trans %}Mój profil{% endtrans %}
                        </a>
                    </li>
                </ul>
            </section>

            <section aria-labelledby="help-heading" class="space-y-4">
                <h2 id="help-heading" class="text-xl font-semibold">
                    {% trans %}Pomoc i informacje{% endtrans %}
                </h2>

                <ul class="list-disc space-y-3 ps-6">
                    <li>
                        <a href="https://bon.vizja.pl/kontakt/" class="underline rounded-sm {{ focusPrimaryWithPadding() }}" rel="noopener noreferrer">
                            {% trans %}Kontakt z BON{% endtrans %}
                        </a>
                    </li>

                    <li>
                        <a href="https://vizja.pl/polityka-prywatnosci" class="underline rounded-sm {{ focusPrimaryWithPadding() }}" rel="noopener noreferrer">
                            {% trans %}Polityka prywatności{% endtrans %}
                        </a>
                    </li>

                    <li>
                        <a href="#" class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                            {% trans %}Deklaracja dostępności{% endtrans %}
                        </a>
                    </li>
                </ul>
            </section>

            <section aria-labelledby="account-heading" class="space-y-4">
                <h2 id="account-heading" class="text-xl font-semibold">
                    {% trans %}Konto{% endtrans %}
                </h2>

                <ul class="list-disc space-y-3 ps-6">
                    <li>
                        <a href="{{ path('logout_full') }}" class="underline rounded-sm {{ focusPrimaryWithPadding() }}">
                            {% trans %}Wyloguj{% endtrans %}
                        </a>
                    </li>
                </ul>
            </section>
        </nav>
    </section>
{% endblock %}
