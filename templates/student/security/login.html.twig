{% extends 'student/_layouts/before-login.html.twig' %}
{% block title %}{% trans %}Zaloguj się{% endtrans %} | Help VIZJA{% endblock %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}

{% block body %}
    <div class="grid lg:h-screen">
        <div class="flex items-center justify-center px-4 py-10 lg:py-0">

            <form action="{{ path('student_login') }}" class="max-w-xl space-y-5 w-full" method="post">
                <input type="hidden" data-controller="csrf-protection" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                {{ flash_messages() }}

                <div class="flex items-center justify-end mb-10">
                    <a class="font-medium inline-flex items-center p-2 rounded-lg text-sm dark:hover:bg-zinc-800 hover:bg-zinc-50 {{ focusPrimary() }}" href="{{ url('student_change_contrast') }}">
                        <span class="sr-only">{% trans %}Zmień kontrast{% endtrans %}</span>
                        <svg id="disability-toggle-on" class="w-6 h-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-width="2" d="M21 12c0 1.2-4.03 6-9 6s-9-4.8-9-6c0-1.2 4.03-6 9-6s9 4.8 9 6Z" />
                            <path stroke="currentColor" stroke-width="2" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                        </svg>
                    </a>
                    {% include 'admin/_components/change-theme.html.twig' %}


                    {% include 'student/_components/change-language.html.twig' %}

                    <div class="bg-white border-2 border-zinc-100 hidden list-none my-4 rounded-lg text-base w-48 z-50 dark:bg-zinc-800 dark:border-zinc-600 {{ focusPrimary() }}"
                        id="language-dropdown">
                        <ul role="none">
                            <li>
                                <a href="#" class="block px-4 py-2 rounded-lg text-sm dark:hover:bg-zinc-700 hover:bg-zinc-100 {{ focusPrimary() }}" role="menuitem">
                                    <div class="inline-flex items-center">
                                        <svg class="h-4 me-2 rounded-lg w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
                                            <mask id="pl" fill="#fff">
                                                <circle cx="256" cy="256" r="256" />
                                            </mask>
                                            <g mask="url(#pl)">
                                                <path fill="#fff" d="M0 0h512v256H0z" />
                                                <path fill="#dc143c" d="M0 256h512v256H0z" />
                                            </g>
                                        </svg>
                                        Polski
                                    </div>
                                </a>
                            </li>
                            <li>
                                <a href="#" class="block px-4 py-2 rounded-lg text-sm dark:hover:bg-zinc-700 hover:bg-zinc-100 {{ focusPrimary() }}" role="menuitem">
                                    <div class="inline-flex items-center">
                                        <svg class="h-4 me-2 rounded-lg w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
                                            <mask id="uk" fill="#fff">
                                                <circle cx="256" cy="256" r="256" />
                                            </mask>
                                            <g mask="url(#uk)">
                                                <path fill="#012169" d="M0 0h512v512H0z" />
                                                <path fill="#fff" d="M0 0l512 512M512 0L0 512" />
                                                <path fill="#C8102E" d="M0 0l512 512M512 0L0 512" stroke-width="60" stroke="#C8102E" />
                                                <path fill="#fff" d="M208 0h96v512h-96zM0 208h512v96H0z" />
                                                <path fill="#C8102E" d="M224 0h64v512h-64zM0 224h512v64H0z" />
                                            </g>
                                        </svg>
                                        English
                                    </div>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

                <figure class="max-w-lg mx-auto">
                    {#                    {% if app.request.locale == 'pl' %} #}
                    {#                        <img alt="{% trans %}Logo Uniwersytetu VIZJA{% endtrans %}" class="block max-w-9/12 mx-auto dark:hidden" src="{{ asset('images/logo/pl-vertical.png') }}"> #}
                    {#                        <img alt="{% trans %}Logo Uniwersytetu VIZJA{% endtrans %}" class="hidden max-w-9/12 mx-auto dark:block" src="{{ asset('images/logo/pl-vertical-transparent.png') }}"> #}
                    {#                    {% elseif app.request.locale == 'en' %} #}
                    {#                        <img alt="{% trans %}VIZJA University logo{% endtrans %}" class="block max-w-9/12 mx-auto dark:hidden" src="{{ asset('images/logo/pl-vertical.png') }}"> #}
                    {#                        <img alt="{% trans %}VIZJA University logo{% endtrans %}" class="hidden max-w-9/12 mx-auto dark:block" src="{{ asset('images/logo/pl-vertical-transparent.png') }}"> #}
                    {#                    {% endif %} #}

                    {% if app.request.locale == 'pl' %}
                        <img alt="{% trans %}Uniwersytet VIZJA{% endtrans %}"
                            class="block max-w-9/12 mx-auto dark:hidden"
                            src="{{ asset('images/logo/pl-vertical.png') }}">
                    {% elseif app.request.locale == 'en' %}
                        <img alt="{% trans %}VIZJA University{% endtrans %}"
                            class="block max-w-9/12 mx-auto dark:hidden"
                            src="{{ asset('images/logo/en-vertical.jpg') }}">
                    {% endif %}
                </figure>

                <a href="{{ path('security_azure_login') }}"
                    class="font-medium inline-flex items-center justify-center me-2 px-5 py-2.5 rounded-lg text-m w-full dark:hover:bg-zinc-700 focus:outline-none focus:ring-3 focus:ring-blue-300 hover:bg-zinc-100"
                    tabindex="5"
                    type="button"
                >
                    <svg class="h-7 mr-2 w-7" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                        <path clip-rule="evenodd" d="M3.005 12 3 6.408l6.8-.923v6.517H3.005ZM11 5.32 19.997 4v8H11V5.32ZM20.067 13l-.069 8-9.065-1.275L11 13h9.067ZM9.8 19.58l-6.795-.931V13H9.8v6.58Z"
                            fill="currentColor" fill-rule="evenodd"></path>
                    </svg>
                    {% trans %}Zaloguj się kontem Office 365{% endtrans %}
                </a>

                <p class="flex items-center text-sm text-body">This is just some informational text
                    <button data-popover-target="popover-description" data-popover-placement="bottom-end" type="button">
                        <svg class="w-4 h-4 text-body hover:text-heading ms-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9.529 9.988a2.502 2.502 0 1 1 5 .191A2.441 2.441 0 0 1 12 12.582V14m-.01 3.008H12M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                        <span class="sr-only">Show information</span></button>
                </p>
                <div data-popover id="popover-description" role="tooltip"
                    class="absolute z-10 p-3 invisible inline-block text-sm text-body transition-opacity duration-300 bg-neutral-primary-soft border border-default rounded-base shadow-xs opacity-0 w-72">
                    <div>
                        <h3 class="font-semibold text-heading mb-2">Activity growth - Incremental</h3>
                        <p class="mb-4">Report helps navigate cumulative growth of community activities. Ideally, the chart should have a growing trend, as stagnating chart signifies a significant
                            decrease of community activity.</p>
                        <h3 class="font-semibold text-heading mb-2">Calculation</h3>
                        <p class="mb-4">For each date bucket, the all-time volume of activities is calculated. This means that activities in period n contain all activities up to period n, plus the
                            activities generated by your community in period.</p>
                        <a href="#" class="flex items-center font-medium text-fg-brand hover:underline">
                            Read more
                            <svg class="w-4 h-4 ms-1 rtl:rotate-180" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 12H5m14 0-4 4m4-4-4-4" />
                            </svg>
                        </a>
                    </div>
                    <div data-popper-arrow></div>
                </div>

                <div class="flex items-center">
                    <div class="bg-zinc-100 h-0.5 w-full dark:bg-zinc-700"></div>
                    <div class="px-5 text-center text-zinc-500 dark:text-zinc-300">{% trans %}albo{% endtrans %}</div>
                    <div class="bg-zinc-100 h-0.5 w-full dark:bg-zinc-700"></div>
                </div>

                {% if error %}
                    <div class="bg-red-50 mb-4 p-4 rounded-lg text-center text-red-800 text-sm dark:bg-zinc-800 dark:text-red-400" role="alert">
                        <span class="font-medium">
                            {% trans %}Błąd{% endtrans %}!
                        </span>
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <div>
                    <label for="username" class="block font-medium mb-2 text-sm">
                        {% trans %}Email{% endtrans %}
                    </label>
                    <input type="text"
                        class="bg-zinc-100 block border-none p-2.5 rounded-lg text-sm w-full dark:bg-zinc-700 dark:placeholder-zinc-400 focus:outline-none focus:ring-3 focus:ring-blue-300 {{ borderPrimary() }}"
                        id="username"
                        name="_username"
                        tabindex="1"
                        value="{{ last_username }}"
                    />
                </div>
                <div>
                    <label for="password" class="block font-medium mb-2 text-sm">
                        {% trans %}Hasło{% endtrans %}
                    </label>
                    <input type="password"
                        autocomplete="off"
                        class="bg-zinc-100 block border-none p-2.5 rounded-lg text-sm w-full dark:bg-zinc-700 dark:placeholder-zinc-400 focus:outline-none focus:ring-3 focus:ring-blue-300"
                        id="password"
                        name="_password"
                        tabindex="2"
                    />
                </div>
                <div class="flex justify-between items-center">
                    <a href="{{ path('app_forgot_password_request') }}" class="{{ buttonSecondary() }}">{% trans %}Nie pamiętam hasła{% endtrans %}</a>
                    <button type="submit"
                        class="{{ buttonPrimary() }} cursor-pointer"
                        tabindex="4"
                    >
                        {% trans %}Zaloguj się{% endtrans %}
                    </button>
                </div>
                <div class="flex items-start">
                    <div class="flex h-5 items-center">
                        <input type="checkbox"
                            class="bg-zinc-100 border-none h-4 rounded-sm w-4 dark:bg-zinc-700 dark:border-zinc-600 dark:ring-offset-zinc-800 focus:outline-none focus:ring-3 focus:ring-blue-300"
                            id="remember"
                            tabindex="3"
                        />
                    </div>

                    <label for="remember" class="font-medium ms-2 text-sm">
                        {% trans %}Zapamiętaj mnie{% endtrans %}
                    </label>
                </div>

                <a href="{{ path('guest_register') }}"
                    class="cursor-pointer block text-center {{ buttonPrimary() }} w-full">
                    {% trans %}Załóż konto{% endtrans %}
                </a>

                <a href="{{ path('guest_dashboard') }}"
                    class="cursor-pointer block text-center {{ buttonPrimary() }} w-full">
                    {% trans %}Wejdź na stronę, jako gość{% endtrans %}
                </a>
            </form>

        </div>
    </div>
{% endblock %}
