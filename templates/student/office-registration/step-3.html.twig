{% extends 'student/_layouts/after-login.html.twig' %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}

{% block title %}{% trans %}Zapis na wizytę w BON - krok 3{% endtrans %} | Help VIZJA{% endblock %}

{% block body %}
    <section class="space-y-8">
        <header class="space-y-2">
            <h1 id="page-title" class="font-semibold text-xl md:text-2xl lg:text-3xl">
                {% trans %}Wizyta w BON{% endtrans %}
            </h1>
            <p class="text-sm md:text-base text-zinc-600 dark:text-zinc-300">
                {% trans %}Sprawdź szczegóły rezerwacji. W razie potrzeby możesz ją anulować.{% endtrans %}
            </p>
        </header>

        {% include 'student/office-registration/_partials/stepper.html.twig' with { currentStep: 3 } %}

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded-lg p-4 {{ borderPrimary() }} bg-zinc-50 dark:bg-zinc-900">
                    <p class="text-sm font-medium">{{ message }}</p>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="space-y-3">
            <h2 class="flex font-medium items-center text-md md:text-lg lg:text-xl">
                {% trans %}Krok{% endtrans %} 3. {% trans %}Podsumowanie{% endtrans %}
            </h2>
        </div>

        <div class="grid gap-6 lg:grid-cols-5">
            <aside class="lg:col-span-2">
                <div class="p-5 rounded-lg space-y-4 {{ borderPrimary() }}">
                    <div class="flex items-start space-x-3">
                        <div class="bg-blue-600 flex h-10 items-center justify-center rounded-full w-10">
                            <svg class="h-6 w-6 text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                                <path fill-rule="evenodd"
                                      d="M2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10S2 17.523 2 12Zm11-4a1 1 0 1 0-2 0v4a1 1 0 0 0 .293.707l3 3a1 1 0 0 0 1.414-1.414L13 11.586V8Z"
                                      clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="space-y-1">
                            <h3 class="font-semibold text-lg">{% trans %}Rezerwacja czeka na potwierdzenie przez pracownika BON{% endtrans %}</h3>
                            <p class="text-left text-sm text-zinc-600 dark:text-zinc-300">
                                {% trans %}Otrzymaliśmy Twoją prośbę o spotkanie. <strong>Teraz Twoja wizyta czeka na potwierdzenie przez pracownika BON.</strong> Informację otrzymasz mailem oraz
                                możesz sprawdzić
                                status swojej rezerwacji w Centrum zapisów.
                            </p>
                            <p class="mt-3 text-left text-sm text-zinc-600 dark:text-zinc-300">
                                Jeśli zmienisz zdanie, możesz samodzielnie anulować termin w zakładce
                                <strong>"Moje wizyty"</strong>, maksymalnie <strong>24
                                    godziny</strong> przed rozpoczęciem wizyty{% endtrans %}
                            </p>
                        </div>
                    </div>

                    <div class="rounded-lg p-3 bg-amber-50 text-amber-900 dark:bg-amber-950/30 dark:text-amber-200">
                        <p class="text-sm">
                            <span class="font-semibold">{% trans %}Uwaga:{% endtrans %}</span>
                            {% trans %}Anulowanie jest natychmiastowe i nie wymaga dodatkowego potwierdzenia mailowego.{% endtrans %}
                        </p>
                    </div>

                    <div class="space-y-3">
                        <a class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }} w-full"
                           href="{{ path('student_registration_center_my_registrations') }}">
                            {% trans %}Moje wizyty{% endtrans %}
                        </a>
                    </div>
                </div>
            </aside>

            <div class="lg:col-span-2">
                <div class="p-5 rounded-lg space-y-4 {{ borderPrimary() }}">
                    <div class="flex items-center space-x-3">
                        <div class="bg-blue-700 flex h-10 items-center justify-center rounded-full w-10 dark:bg-yellow-400">
                            <svg class="h-6 text-white w-6 dark:text-zinc-950" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                                <path fill-rule="evenodd" d="M12 4a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm-2 9a4 4 0 0 0-4 4v1a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-1a4 4 0 0 0-4-4h-4Z" clip-rule="evenodd"></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-semibold text-lg">{% trans %}Twoja rezerwacja{% endtrans %}</h3>
                            <p class="text-sm text-zinc-600 dark:text-zinc-300">
                                {% trans %}Poniżej znajdują się szczegóły wybranego terminu.{% endtrans %}
                            </p>
                        </div>
                    </div>

                    <dl class="divide-y divide-zinc-200 dark:divide-zinc-600">
                        <div class="flex items-center justify-between py-3">
                            <dt class="text-sm text-zinc-600 dark:text-zinc-300">{% trans %}Imię i nazwisko{% endtrans %}</dt>
                            <dd class="text-sm font-semibold">
                                {{ myRegistration.student.firstName }} {{ myRegistration.student.lastName }}
                            </dd>
                        </div>

                        <div class="flex items-center justify-between py-3">
                            <dt class="text-sm text-zinc-600 dark:text-zinc-300">{% trans %}Adres e-mail{% endtrans %}</dt>
                            <dd class="text-sm font-semibold">
                                {{ myRegistration.student.email }}
                            </dd>
                        </div>

                        <div class="flex items-center justify-between py-3">
                            <dt class="text-sm text-zinc-600 dark:text-zinc-300">{% trans %}Dzień wizyty{% endtrans %}</dt>
                            <dd class="text-sm font-semibold">{{ registration.startAt|date('d.m.Y') }}</dd>
                        </div>

                        <div class="flex items-center justify-between py-3">
                            <dt class="text-sm text-zinc-600 dark:text-zinc-300">{% trans %}Godzina wizyty{% endtrans %}</dt>
                            <dd class="text-sm font-semibold">{{ registration.startAt|date('H:i') }} - {{ registration.endAt|date('H:i') }}</dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
