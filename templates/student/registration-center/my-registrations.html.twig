{% extends 'student/_layouts/after-login.html.twig' %}
{% block title %}{% trans %}Moje zapisy{% endtrans %} | Help VIZJA{% endblock %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}

{% block body %}
    <section class="p-5 rounded-2xl">
        <header class="mb-6 flex items-start justify-between gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-white">{% trans %}Moje zapisy{% endtrans %}</h1>
            </div>
        </header>
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">

            {% if is_granted('ROLE_STUDENT') %}
                <a href="{{ url('student_registration_center_my_registrations') }}"
                   class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                    <div class="flex items-start gap-4">
                        <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">

                            <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.21448 20v-9l-4 1.125V20h4Zm0 0V6.66667m0 13.33333h2.00002m6-11V6.66667m2 1.33333-6-4-6.00002 4m5.00002 1h2m-2 3h1m3 4v-2.5c0-.8284.6716-1.5 1.5-1.5s1.5.6716 1.5 1.5V16m-4 0h5c.5523 0 1 .4477 1 1v2c0 .5523-.4477 1-1 1h-5c-.5523 0-1-.4477-1-1v-2c0-.5523.4477-1 1-1Z"/>
                            </svg>


                        </div>

                        <div>
                            <h3 class="font-semibold text-zinc-900 dark:text-white">
                                {% trans %}Moje wizyty w BON{% endtrans %}
                            </h3>
                            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                                {% trans %}Sprawdź status umówionych wizyt{% endtrans %}
                            </p>
                        </div>
                    </div>
                </a>
            {% endif %}

            <a href="{{ url('student_my_registrations') }}"
               class="cursor-pointer rounded-2xl border-2 border-zinc-500 bg-white p-5 shadow-sm transition hover:border-blue-600 hover:shadow-md dark:border-zinc-500 dark:bg-zinc-800 dark:hover:border-yellow-400 {{ focusPrimaryWithPadding() }}">
                <div class="flex items-start gap-4">
                    <div class="rounded-xl bg-blue-50 p-3 text-blue-700 dark:bg-zinc-900 dark:text-yellow-300">

                        <svg class="w-6 h-6 text-zinc-800 dark:text-yellow-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m11.5 11.5 2.071 1.994M4 10h5m11 0h-1.5M12 7V4M7 7V4m10 3V4m-7 13H8v-2l5.227-5.292a1.46 1.46 0 0 1 2.065 2.065L10 17Zm-5 3h14a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1Z"/>
                        </svg>

                    </div>

                    <div>
                        <h3 class="font-semibold text-zinc-900 dark:text-white">
                            {% trans %}Moje zapisy na konsultacje{% endtrans %}
                        </h3>
                        <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                            {% trans %}Sprawdź szczegóły umówionych konsultacji{% endtrans %}
                        </p>
                    </div>
                </div>
            </a>
        </div>
    </section>
{% endblock %}
