        <div class="space-y-4">
            <div id="file_wrapper"
                 class="space-y-2"
                 data-existing-count="{{ files|length }}"
                 data-prototype="{{ form_widget(form.files.vars.prototype)|e('html_attr') }}"
                 data-max="3"
                 data-entry-class="file-field"
                 data-index="{{ form.files|length }}"
            >
                {% for fileField in form.files %}
                    {% if fileField.vars.value %}
                        <div class="file-field rounded-xl bg-zinc-50 px-4 py-2 dark:bg-zinc-800 {{ borderPrimary() }}">
                            <div class="sr-only">
                                {{ form_widget(fileField, {
                                    attr: {
                                        class: 'file-input'
                                    }
                                }) }}
                            </div>

                            <div class="flex items-center justify-between gap-3">
                                <span class="file-name truncate text-sm font-semibold">
                                    {{ fileField.vars.value.originalName }}
                                </span>

                                <button
                                    type="button"
                                    class="{{ buttonDelete() }} remove-file-btn inline-flex items-center rounded-xl px-3 py-1.5 text-sm font-medium {{ focusPrimaryWithPadding() }}"
                                    data-csrf="{{ csrf_token('delete_application_file_' ~ fileField.vars.value.id) }}"
                                    data-href="{{ url('student_application_file_delete', { fileId: fileField.vars.value.id }) }}"
                                >
                                    {% trans %}Usuń{% endtrans %}
                                </button>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>

            <div class="space-y-2">
                <button
                    type="button"
                    id="add_file_btn"
                    class="add_file_btn cursor-pointer {{ buttonPrimary() }} {{ focusPrimaryWithPadding() }} disabled:opacity-50 disabled:cursor-not-allowed"
                    aria-controls="file_wrapper"
                    aria-describedby="files_hint files_counter"
                    data-wrapper-id="file_wrapper"
                >
                    {% trans %}Dodaj załącznik{% endtrans %}
                </button>

                <span id="files_live"
                      class="sr-only"
                      role="status"
                      aria-live="polite"
                      aria-atomic="true"></span>
            </div>

            <p id="files_counter" class="text-sm">
                {% trans %}Liczba dodanych plików{% endtrans %}:
                <span data-counter-for="file_wrapper">
{#                {{ files|length + form.files|length }}#}
{#                    {{ form.files|length }}#}
                    {{ files|length }}
            </span>/3
            </p>

            {{ form_errors(form.files) }}
        </div>
