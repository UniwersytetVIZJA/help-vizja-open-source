<script>
    document.addEventListener('DOMContentLoaded', function () {
        const textarea = document.getElementById('{{ form.description.vars.id }}');
        const counter = document.getElementById('desc-count');
        const phoneInput = document.getElementById('{{ form.phone.number.vars.id }}');

        if (textarea && counter) {
            const update = () => {
                counter.textContent = textarea.value.length;
            };

            update();
            textarea.addEventListener('input', update);
        }

        if (phoneInput) {
            const sanitizePhone = () => {
                phoneInput.value = phoneInput.value.replace(/\D/g, '');
            };

            phoneInput.addEventListener('input', sanitizePhone);
            phoneInput.addEventListener('paste', function () {
                requestAnimationFrame(sanitizePhone);
            });
            phoneInput.addEventListener('drop', function () {
                requestAnimationFrame(sanitizePhone);
            });
            phoneInput.addEventListener('beforeinput', function (e) {
                if (e.data && /\D/.test(e.data)) {
                    e.preventDefault();
                }
            });

            sanitizePhone();
        }
    });
</script>


<script>
    (function () {
        function byId(id) {
            return document.getElementById(id);
        }

        function getEntryClass(wrapper) {
            return wrapper?.dataset.entryClass || 'file-field';
        }

        function getFileFields(wrapper) {
            if (!wrapper) {
                return [];
            }

            return Array.from(wrapper.querySelectorAll('.' + getEntryClass(wrapper)));
        }

        function updateCounter(wrapper) {
            if (!wrapper) {
                return 0;
            }

            const count = getFileFields(wrapper).length;

            const counter = document.querySelector(
                '[data-counter-for="' + wrapper.id + '"]'
            );

            if (counter) {
                counter.textContent = String(count);

                counter.setAttribute(
                    'aria-label',
                    '{% trans %}Liczba dodanych plików{% endtrans %}: ' + count
                );
            }

            return count;
        }

        function findLiveRegion(addBtn) {
            return addBtn.closest('div')?.querySelector('.files_live')
                || document.getElementById('files_live')
                || null;
        }

        function announce(liveRegion, message) {
            if (!liveRegion) {
                return;
            }

            liveRegion.setAttribute('role', 'status');
            liveRegion.setAttribute('aria-live', 'polite');
            liveRegion.setAttribute('aria-atomic', 'true');

            liveRegion.textContent = '';

            window.setTimeout(function () {
                liveRegion.textContent = message;
            }, 50);
        }

        function setBtnState(wrapper, addBtn) {
            if (!wrapper || !addBtn) {
                return;
            }

            const max = parseInt(wrapper.dataset.max || '3', 10);
            const count = updateCounter(wrapper);
            const disabled = count >= max;

            addBtn.disabled = disabled;
            addBtn.setAttribute('aria-disabled', String(disabled));

            if (disabled) {
                addBtn.setAttribute(
                    'aria-label',
                    '{% trans %}Nie można dodać więcej plików. Osiągnięto limit{% endtrans %}: ' + max
                );
            } else {
                addBtn.setAttribute(
                    'aria-label',
                    '{% trans %}Dodaj plik. Dodano{% endtrans %}: ' + count + ' {% trans %}z{% endtrans %} ' + max
                );
            }
        }

        function focusBestTarget(wrapper, addBtn) {
            if (!wrapper || !addBtn) {
                return;
            }

            const fields = getFileFields(wrapper);
            const lastRemoveBtn = fields.length
                ? fields[fields.length - 1].querySelector('.remove-file-btn')
                : null;

            if (lastRemoveBtn) {
                lastRemoveBtn.focus();
                return;
            }

            addBtn.focus();
        }

        async function removeFile(container, wrapper, addBtn, removeBtn, live) {
            const href = removeBtn?.dataset.href;
            const csrf = removeBtn?.dataset.csrf;

            const fileNameElement = container.querySelector('.file-name');
            const fileName = fileNameElement?.textContent?.trim() || '{% trans %}plik{% endtrans %}';

            if (href && csrf) {
                const deleteUrl = href + '?_token=' + encodeURIComponent(csrf);

                try {
                    const response = await fetch(deleteUrl, {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        announce(live, '{% trans %}Nie udało się usunąć pliku{% endtrans %}: ' + fileName + '.');
                        return;
                    }
                } catch (error) {
                    announce(live, '{% trans %}Nie udało się usunąć pliku{% endtrans %}: ' + fileName + '.');
                    return;
                }
            }

            container.remove();

            const count = updateCounter(wrapper);
            setBtnState(wrapper, addBtn);

            announce(
                live,
                '{% trans %}Usunięto plik{% endtrans %}: ' + fileName + '. {% trans %}Liczba dodanych plików{% endtrans %}: ' + count + '.'
            );

            focusBestTarget(wrapper, addBtn);
        }

        function prepareExistingFileFields(wrapper, addBtn, live) {
            getFileFields(wrapper).forEach(function (container) {
                const removeBtn = container.querySelector('.remove-file-btn');
                const fileName = container.querySelector('.file-name')?.textContent?.trim();

                if (!removeBtn) {
                    return;
                }

                if (fileName) {
                    removeBtn.setAttribute('aria-label', '{% trans %}Usuń plik{% endtrans %}: ' + fileName);
                }

                removeBtn.addEventListener('click', function () {
                    removeFile(container, wrapper, addBtn, removeBtn, live);
                });
            });
        }

        function createFileField(html, wrapper, addBtn, live) {
            const container = document.createElement('div');

            container.className = 'file-field rounded-xl bg-zinc-50 px-4 py-2 dark:bg-zinc-800 {{ borderPrimary() }}';
            container.innerHTML =
                '<div class="sr-only">' + html + '</div>' +
                '<div class="flex items-center justify-between gap-3">' +
                '<span class="file-name truncate text-m font-semibold">{% trans %}Nie wybrano pliku{% endtrans %}</span>' +
                '<button type="button" class="{{ buttonDanger() }} remove-file-btn inline-flex items-center rounded-xl px-3 py-1.5 text-sm font-medium" aria-label="{% trans %}Usuń niewybrany plik{% endtrans %}">' +
                '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">' +
                '<path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />' +
                '</svg>' +
                '<span>{% trans %}Usuń{% endtrans %}</span>' +
                '</button>' +
                '</div>';

            const fileInput = container.querySelector('input[type="file"]');
            const fileName = container.querySelector('.file-name');
            const removeBtn = container.querySelector('.remove-file-btn');

            if (!fileInput) {
                return;
            }

            fileInput.setAttribute('accept', 'application/pdf,.pdf');
            fileInput.classList.add('sr-only');

            removeBtn.addEventListener('click', function () {
                removeFile(container, wrapper, addBtn, removeBtn, live);
            });

            wrapper.appendChild(container);

            let fileChosen = false;

            fileInput.addEventListener('change', function () {
                if (fileInput.files && fileInput.files.length > 0) {
                    const selectedFile = fileInput.files[0];
                    const selectedFileName = selectedFile.name || '';
                    const selectedFileType = selectedFile.type || '';

                    const isPdf =
                        selectedFileType === 'application/pdf'
                        || selectedFileName.toLowerCase().endsWith('.pdf');

                    if (!isPdf) {
                        fileInput.value = '';
                        fileChosen = false;

                        if (fileName) {
                            fileName.textContent = '{% trans %}Nie wybrano pliku{% endtrans %}';
                        }

                        removeBtn.setAttribute(
                            'aria-label',
                            '{% trans %}Usuń niewybrany plik{% endtrans %}'
                        );

                        announce(live, '{% trans %}Można wybrać tylko plik PDF.{% endtrans %}');
                        alert('{% trans %}Można wybrać tylko plik PDF.{% endtrans %}');

                        return;
                    }

                    fileChosen = true;

                    if (fileName) {
                        fileName.textContent = selectedFileName;
                    }

                    removeBtn.setAttribute(
                        'aria-label',
                        '{% trans %}Usuń plik{% endtrans %}: ' + selectedFileName
                    );

                    setBtnState(wrapper, addBtn);

                    announce(
                        live,
                        '{% trans %}Dodano plik{% endtrans %}: ' + selectedFileName + '. {% trans %}Liczba dodanych plików{% endtrans %}: ' + updateCounter(wrapper) + '.'
                    );

                    removeBtn.focus();
                }
            });

            window.addEventListener('focus', function handleWindowFocus() {
                window.setTimeout(function () {
                    window.removeEventListener('focus', handleWindowFocus);

                    if (!fileChosen && (!fileInput.files || fileInput.files.length === 0)) {
                        container.remove();
                        setBtnState(wrapper, addBtn);
                        announce(live, '{% trans %}Anulowano wybór pliku{% endtrans %}.');
                        addBtn.focus();
                    }
                }, 300);
            }, { once: true });

            setBtnState(wrapper, addBtn);

            fileInput.click();
        }

        function wireAddButton(addBtn) {
            const wrapperId = addBtn.getAttribute('data-wrapper-id');
            const wrapper = byId(wrapperId);

            if (!wrapper) {
                return;
            }

            let index = parseInt(wrapper.dataset.index || '0', 10);
            const live = findLiveRegion(addBtn);

            prepareExistingFileFields(wrapper, addBtn, live);
            setBtnState(wrapper, addBtn);

            addBtn.addEventListener('click', function () {
                const max = parseInt(wrapper.dataset.max || '3', 10);
                const count = updateCounter(wrapper);

                if (count >= max) {
                    announce(live, '{% trans %}Nie można dodać więcej plików. Osiągnięto limit{% endtrans %}: ' + max + '.');
                    return;
                }

                const prototype = wrapper.dataset.prototype;
                const html = prototype.replace(/__name__/g, index);

                index++;
                wrapper.dataset.index = String(index);

                createFileField(html, wrapper, addBtn, live);
            });
        }

        document.querySelectorAll('.remove-existing-file-btn').forEach(btn => {
            btn.addEventListener('click', async function () {
                const container = btn.closest('.existing-file');

                if (!container) {
                    return;
                }

                const deleteUrl = container.dataset.deleteUrl;

                if (!deleteUrl) {
                    container.remove();
                    return;
                }

                try {
                    const response = await fetch(deleteUrl, {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        return;
                    }

                    const wrapper = container.closest('.space-y-4')
                        ?.querySelector('[data-existing-count]');

                    if (wrapper) {
                        const current = parseInt(
                            wrapper.dataset.existingCount || '0',
                            10
                        );

                        wrapper.dataset.existingCount = String(
                            Math.max(0, current - 1)
                        );

                        updateCounter(wrapper);
                    }

                    container.remove();
                } catch (e) {
                    console.error(e);
                }
            });
        });

        document.addEventListener('DOMContentLoaded', function () {
            const summary = byId('form_error_summary');

            if (summary) {
                summary.setAttribute('tabindex', '-1');
                summary.focus();
            }

            document.querySelectorAll('.add_file_btn').forEach(wireAddButton);

            const existingWrapper = byId('existing_files_wrapper');
            const anyLive = document.querySelector('.files_live') || null;

            if (existingWrapper) {
                existingWrapper.querySelectorAll('.file-field').forEach(function (container) {
                    const removeBtn = container.querySelector('.remove-file-btn');
                    const fileName = container.querySelector('.file-name')?.textContent?.trim();

                    if (!removeBtn) {
                        return;
                    }

                    if (fileName) {
                        removeBtn.setAttribute('aria-label', '{% trans %}Usuń plik{% endtrans %}: ' + fileName);
                    }

                    removeBtn.addEventListener('click', function () {
                        removeFile(container, null, null, null, anyLive);
                    });
                });
            }
        });

        document.addEventListener('click', function (event) {
            const target = event.target.closest('[data-focus-target]');

            if (!target) {
                return;
            }

            const id = target.getAttribute('data-focus-target');
            const field = document.getElementById(id);

            if (field) {
                field.focus();
            }
        });
    })();
</script>

<script>
    document.querySelectorAll('.remove-existing-file-btn').forEach(btn => {
        btn.addEventListener('click', async function () {
            const container = btn.closest('.existing-file');

            if (!container) {
                return;
            }

            const deleteUrl = container.dataset.deleteUrl;
            const csrf = container.dataset.csrf;

            if (!deleteUrl || !csrf) {
                return;
            }

            try {
                const response = await fetch(deleteUrl, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: new URLSearchParams({
                        _token: csrf
                    })
                });

                if (!response.ok) {
                    return;
                }

                const wrapper = container.closest('.space-y-4')
                    ?.querySelector('[data-existing-count]');

                if (wrapper) {
                    const current = parseInt(wrapper.dataset.existingCount || '0', 10);

                    wrapper.dataset.existingCount = String(
                        Math.max(0, current - 1)
                    );

                    const counter = document.querySelector(
                        '[data-counter-for="' + wrapper.id + '"]'
                    );

                    if (counter) {
                        counter.textContent = wrapper.dataset.existingCount;
                    }
                }

                container.remove();
            } catch (e) {
                console.error(e);
            }
        });
    });
</script>

<script>
    (function () {
        function isPdf(file) {
            if (!file) {
                return false;
            }

            const name = file.name || '';
            const type = file.type || '';

            return type === 'application/pdf' || name.toLowerCase().endsWith('.pdf');
        }

        function preparePdfInput(input) {
            if (!input || input.dataset.pdfOnlyInit === '1') {
                return;
            }

            input.dataset.pdfOnlyInit = '1';
            input.setAttribute('accept', 'application/pdf,.pdf');

            input.addEventListener('change', function () {
                const file = input.files && input.files[0];

                if (!file) {
                    return;
                }

                if (isPdf(file)) {
                    return;
                }

                input.value = '';

                const container = input.closest('.file-field');
                const fileName = container?.querySelector('.file-name');
                const removeBtn = container?.querySelector('.remove-file-btn');
                const live = document.getElementById('files_live');

                if (fileName) {
                    fileName.textContent = '{% trans %}Nie wybrano pliku{% endtrans %}';
                }

                if (removeBtn) {
                    removeBtn.setAttribute(
                        'aria-label',
                        '{% trans %}Usuń niewybrany plik{% endtrans %}'
                    );
                }

                if (live) {
                    live.textContent = '';

                    window.setTimeout(function () {
                        live.textContent = '{% trans %}Można wybrać tylko plik PDF.{% endtrans %}';
                    }, 50);
                }

                alert('{% trans %}Można wybrać tylko plik PDF.{% endtrans %}');
            });
        }

        function initPdfOnlyFiles() {
            document
                .querySelectorAll('#file_wrapper input[type="file"]')
                .forEach(preparePdfInput);
        }

        document.addEventListener('DOMContentLoaded', initPdfOnlyFiles);

        const wrapper = document.getElementById('file_wrapper');

        if (wrapper) {
            const observer = new MutationObserver(initPdfOnlyFiles);

            observer.observe(wrapper, {
                childList: true,
                subtree: true
            });
        }
    })();
</script>
