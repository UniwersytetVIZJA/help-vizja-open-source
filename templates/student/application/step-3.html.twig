{% extends 'student/_layouts/after-login.html.twig' %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}
{% block title %}{% trans %}Składanie wniosku - krok 3{% endtrans %} | Help VIZJA{% endblock %}

{% block body %}
    <h1 id="page-title" class="wrap-break-word text-xl font-semibold md:text-2xl lg:text-3xl">
        {% trans %}Złóż wniosek{% endtrans %}
    </h1>

    {% set visibleStep = adaptationRequired ? 4 : 3 %}

    {% include 'student/application/_partials/stepper.html.twig' with {
        currentStep: visibleStep,
        adaptationRequired: adaptationRequired
    } %}

    <div class="w-full max-w-4xl space-y-4 min-w-0">
        <h2 class="flex items-center wrap-break-word font-medium text-md md:text-lg lg:text-xl">
            {% trans %}Krok{% endtrans %} {{ visibleStep }}. {% trans %}Sprawdź dane i złóż wniosek{% endtrans %}
        </h2>

        <div class="mx-auto grid max-w-6xl py-10 min-w-0">
            <div class="min-w-0">
                <div class="space-y-4 rounded-lg p-4 min-w-0 {{ borderPrimary() }}">
                    <div class="flex min-w-0 items-center space-x-3">
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-blue-700 dark:bg-yellow-400">
                            <svg class="h-6 w-6 text-white dark:text-zinc-950" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                                <path fill-rule="evenodd" d="M12 4a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm-2 9a4 4 0 0 0-4 4v1a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-1a4 4 0 0 0-4-4h-4Z" clip-rule="evenodd"></path>
                            </svg>
                        </div>
                        <h2 class="wrap-break-word text-lg font-semibold">{% trans %}Podstawowe informacje{% endtrans %}</h2>
                    </div>
                    <ul class="space-y-2 divide-y divide-zinc-200 dark:divide-zinc-600">
                        <li class="flex flex-col gap-1 py-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                            <span class="wrap-break-word">{% trans %}Numer albumu{% endtrans %}</span>
                            <span class="wrap-break-word font-medium">{{ application.albumNumber }}</span>
                        </li>
                        <li class="flex flex-col gap-1 py-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                            <span class="wrap-break-word">{% trans %}Imię i nazwisko{% endtrans %}</span>
                            <span class="wrap-break-word font-medium">{{ application.student.firstName }} {{ application.student.lastName }}</span>
                        </li>
                        <li class="flex flex-col gap-1 py-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                            <span class="wrap-break-word">{% trans %}Adres e-mail{% endtrans %}</span>
                            <span class="wrap-break-word font-medium">{{ shortenEmail(application.student.email) }}</span>
                        </li>
                        <li class="flex flex-col gap-1 py-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                            <span class="wrap-break-word">{% trans %}Telefon{% endtrans %}</span>
                            <span class="wrap-break-word font-medium">+{{ application.phone.countryCode }} {{ application.phone.nationalNumber }}</span>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="min-w-0">
                <div class="space-y-4 rounded-lg p-4 min-w-0 {{ borderPrimary() }}">
                    <div class="flex min-w-0 items-center space-x-3">
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-blue-700 dark:bg-yellow-400">
                            <svg class="h-6 w-6 text-white dark:text-zinc-950" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12.4472 4.10557c-.2815-.14076-.6129-.14076-.8944 0L2.76981 8.49706l9.21949 4.39024L21 8.38195l-8.5528-4.27638Z"></path>
                                <path
                                    d="M5 17.2222v-5.448l6.5701 3.1286c.278.1325.6016.1293.8771-.0084L19 11.618v5.6042c0 .2857-.1229.5583-.3364.7481l-.0025.0022-.0041.0036-.0103.009-.0119.0101-.0181.0152c-.024.02-.0562.0462-.0965.0776-.0807.0627-.1942.1465-.3405.2441-.2926.195-.7171.4455-1.2736.6928C15.7905 19.5208 14.1527 20 12 20c-2.15265 0-3.79045-.4792-4.90614-.9751-.5565-.2473-.98098-.4978-1.27356-.6928-.14631-.0976-.2598-.1814-.34049-.2441-.04036-.0314-.07254-.0576-.09656-.0776-.01201-.01-.02198-.0185-.02991-.0253l-.01038-.009-.00404-.0036-.00174-.0015-.0008-.0007s-.00004 0 .00978-.0112l-.00009-.0012-.01043.0117C5.12215 17.7799 5 17.5079 5 17.2222Zm-3-6.8765 2 .9523V17c0 .5523-.44772 1-1 1s-1-.4477-1-1v-6.6543Z"></path>
                            </svg>
                        </div>
                        <h2 class="wrap-break-word text-lg font-semibold">{% trans %}Studia{% endtrans %}</h2>
                    </div>
                    <ul class="space-y-2 divide-y divide-zinc-200 dark:divide-zinc-600">
                        <li class="flex flex-col gap-1 py-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                            <span class="wrap-break-word">{% trans %}Tryb studiów{% endtrans %}</span>
                            <span class="wrap-break-word font-medium">
                                {% if application.studyMode is same as 'Z' %}
                                    {% trans %}Zaoczny{% endtrans %}
                                {% else %}
                                    {% trans %}Stacjonarny{% endtrans %}
                                {% endif %}
                            </span>
                        </li>
                        <li class="flex flex-col gap-1 py-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                            <span class="wrap-break-word">{% trans %}Kierunek{% endtrans %}</span>
                            <span class="wrap-break-word font-medium">
                                {% if app.locale == 'pl' %}
                                    {{ application.faculty }}
                                {% else %}
                                    {{ application.faculty }}
                                {% endif %}
                            </span>
                        </li>
                        <li class="flex flex-col gap-1 py-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                            <span class="wrap-break-word">{% trans %}Wydział{% endtrans %}</span>
                            <span class="wrap-break-word font-medium">
                                {% if application.department %}
                                    {% if app.locale == 'pl' %}
                                        {{ application.department }}

                                    {% endif %}
                                {% else %}
                                    &mdash;
                                {% endif %}
                            </span>
                        </li>
                        <li class="flex flex-col gap-1 py-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                            <span class="wrap-break-word">{% trans %}Dziekan{% endtrans %}</span>
                            <span class="wrap-break-word font-medium">
                                {% if application.dean %}
                                    {{ application.dean }}
                                {% endif %}
                            </span>
                        </li>
                        <li class="flex flex-col gap-1 py-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                            <span class="wrap-break-word">{% trans %}Semestr{% endtrans %}</span>
                            <span class="wrap-break-word font-medium">
                                {% if application.semester %}
                                    {{ application.semester }}
                                {% endif %}
                            </span>
                        </li>
                        <li class="flex flex-col gap-1 py-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                            <span class="wrap-break-word">{% trans %}Rok{% endtrans %}</span>
                            <span class="wrap-break-word font-medium">
                                {% if application.year %}
                                    {{ application.year }}
                                {% endif %}
                            </span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="min-w-0">
                <div class="space-y-4 rounded-lg p-4 min-w-0 {{ borderPrimary() }}">
                    <div class="flex min-w-0 items-center space-x-3">
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-blue-700 dark:bg-yellow-400">
                            <svg class="h-6 w-6 text-white dark:text-zinc-950" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                                 viewBox="0 0 24 24">
                                <path fill-rule="evenodd"
                                      d="M8 3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1h2a2 2 0 0 1 2 2v15a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h2Zm6 1h-4v2H9a1 1 0 0 0 0 2h6a1 1 0 1 0 0-2h-1V4Zm-6 8a1 1 0 0 1 1-1h6a1 1 0 1 1 0 2H9a1 1 0 0 1-1-1Zm1 3a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2H9Z"
                                      clip-rule="evenodd"></path>
                            </svg>
                        </div>
                        <h2 class="wrap-break-word text-lg font-semibold">{% trans %}Wniosek{% endtrans %}</h2>
                    </div>
                    <ul class="space-y-2 divide-y divide-zinc-200 dark:divide-zinc-600 min-w-0">
                        {% include 'student/application/_form-show/' ~ application.type.hiddenValue ~ '.html.twig' %}
                    </ul>
                </div>
            </div>
            <div class="min-w-0">
                <div class="space-y-4 rounded-lg p-4 min-w-0 {{ borderPrimary() }}">
                    <div class="flex min-w-0 items-center space-x-3">
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-blue-700 dark:bg-yellow-400">
                            <svg class="h-6 w-6 text-white dark:text-zinc-950" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                                 viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M4 15v2a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3v-2m-8 1V4m0 12-4-4m4 4 4-4"></path>
                            </svg>
                        </div>
                        <h2 class="wrap-break-word text-lg font-semibold">{% trans %}Wgrane pliki{% endtrans %}</h2>
                    </div>

                    {% if files is not empty %}
                        <ul class="space-y-2 divide-y divide-zinc-200 dark:divide-zinc-600">
                            {% for file in files %}
                                <li class="flex flex-col gap-1 py-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                                <span class="wrap-break-word">
                                    {{ file.originalName }} ({{ file.extension|upper }}, {{ fileSize }} KB)
                                </span>

                                    <span class="font-medium shrink-0">
                                        <a href="{{ path('student_application_file_show', { fileId: file.id }) }}"
                                           class="{{ linkPrimary() }} {{ focusPrimary() }}"
                                           target="_blank"
                                           rel="noopener noreferrer">

                                            {% trans %}Otwórz{% endtrans %}

                                           <span class="sr-only">
                                                {{ file.originalName }} - {% trans %}otwiera się w nowym oknie{% endtrans %}
                                            </span>
                                        </a>
                                    </span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="wrap-break-word">{% trans %}Brak wgranych plików.{% endtrans %}</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <form action="" class="flex flex-wrap gap-2" method="post">
        <input
            type="hidden"
            name="_token"
            value="{{ csrf_token('submit_application_' ~ application.id) }}"
        >

        <a class="{{ buttonSecondary() }} {{ focusPrimaryWithPadding() }}" href="{{ url('student_fill_application_form') }}">
            {% trans %}Wróć do poprzedniego kroku{% endtrans %}
        </a>

        <button class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}" type="submit">
            {% trans %}Złóż wniosek{% endtrans %}
        </button>
    </form>
{% endblock %}
