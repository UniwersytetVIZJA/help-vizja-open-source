    <li class="flex justify-between py-3">
        <span class="text-zinc-600 dark:text-zinc-300">{% trans %}Imię i nazwisko asystenta{% endtrans %}</span>
        <span class="font-medium text-zinc-900 dark:text-white">{{ application.assistant }}</span>
    </li>

    {% if application.preferences %}
        <li class="flex justify-between py-3">
            <span class="text-zinc-600 dark:text-zinc-300">{% trans %}Preferencje asystenta dydaktycznego{% endtrans %}</span>
            <div class="text-right font-medium text-zinc-900 dark:text-white space-y-1">
                {% for item in application.preferences %}
                    {% if app.locale === 'pl' %}
                    <p>- {{ item.value }}</p>
                    {% else %}
                        <p>- {{ item.valueEnglish }}</p>
                    {% endif %}
                {% else %}
                    <p>—</p>
                {% endfor %}
            </div>
        </li>
    {% endif %}

    <li class="py-3">
    <span class="text-zinc-600 dark:text-zinc-300 block mb-2">
        {% trans %}Zadania{% endtrans %}
    </span>

        <span class="font-medium text-zinc-900 dark:text-white break-words">
        {{ application.assistantTask }}
    </span>
    </li>
    <li class="flex justify-between py-3">
        <span class="text-zinc-600 dark:text-zinc-300">{% trans %}Liczba godzin{% endtrans %}</span>
        <span class="font-medium text-zinc-900 dark:text-white">{{ application.assistantHours }}</span>
    </li>
