{% block email_body %}
    <div style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 15px; line-height: 1.6; color: #1f2933; background-color: #f5f7fa; padding: 24px 16px;">
        <div style="max-width: 640px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; padding: 24px 28px; border: 1px solid #d8e2ec;">

            <p style="margin: 0 0 12px 0; font-size: 16px; color: #52606d;">
                Witaj, <strong>{{ firstName }} {{ lastName }}</strong>,
            </p>

            <p style="margin: 0 0 12px 0;">
                Otrzymaliśmy prośbę o zresetowanie hasła do konta w serwisie <strong>help.vizja.pl</strong>.
            </p>

            <p style="margin: 0 0 12px 0;">
                Aby ustawić nowe hasło, kliknij w poniższy link:
            </p>

            {% set resetUrl = absolute_url(path('app_reset_password', { token: resetToken.token })) %}

            <p style="margin: 0 0 12px 0;">
                <a href="{{ resetUrl }}" style="color: #1a56db; font-weight: 600; word-break: break-word;">
                    {{ resetUrl }}
                </a>
            </p>

            <p style="margin: 0 0 12px 0; font-size: 13px; color: #52606d;">
                Link wygaśnie za:
                <strong>
                    {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}
                </strong>
            </p>

            <p style="margin: 0 0 4px 0; font-size: 13px; color: #52606d;">
                Jeśli to nie Ty wysłałeś/aś prośbę o reset hasła, zignoruj tę wiadomość — Twoje hasło pozostanie bez zmian.
            </p>

            <p style="margin: 12px 0 0 0; font-size: 13px; color: #52606d;">
                Z pozdrowieniami,<br>
                <strong>Zespół Biura ds. Osób z Niepełnosprawnościami</strong>
            </p>
        </div>

        <p style="max-width: 640px; margin: 12px auto 0 auto; font-size: 11px; color: #9fb3c8; text-align: center;">
            To jest wiadomość wygenerowana automatycznie – prosimy na nią nie odpowiadać.
        </p>
    </div>
{% endblock %}
